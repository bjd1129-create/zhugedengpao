<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>诸葛灯泡 - AI智能信号雷达</title>
    <style>
        /* 奶油气泡风格全局样式 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background-color: #fff9e6; /* 浅奶油色背景 */
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(255, 255, 255, 0.1) 0%, transparent 2%),
                radial-gradient(circle at 85% 30%, rgba(255, 255, 255, 0.1) 0%, transparent 2%);
            color: #333;
            line-height: 1.6;
            padding: 20px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        header {
            text-align: center;
            padding: 30px 0;
            margin-bottom: 30px;
            border-bottom: 2px dashed #ffcc00; /* 手绘虚线边框 */
            position: relative;
            overflow: hidden;
        }
        
        h1 {
            font-size: 2.5rem;
            color: #ff6600;
            margin-bottom: 10px;
            text-shadow: 2px 2px 0px rgba(0,0,0,0.1);
        }
        
        .subtitle {
            font-size: 1.2rem;
            color: #666;
            margin-bottom: 20px;
        }
        
        .dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .card {
            background: white;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px; /* 手绘不规则圆角 */
            padding: 25px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            border: 2px solid #ffcc00; /* 黄色边框 */
            position: relative;
            overflow: hidden;
        }
        
        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: linear-gradient(90deg, #ffcc00, #ff9900, #ff6600);
        }
        
        .card-title {
            font-size: 1.3rem;
            color: #ff6600;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px dashed #ffcc00;
        }
        
        .signal-count {
            font-size: 2.5rem;
            font-weight: bold;
            color: #ff6600;
            text-align: center;
            margin: 20px 0;
        }
        
        .category-list, .status-list {
            list-style: none;
        }
        
        .category-item, .status-item {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px dashed #eee;
        }
        
        .activity-feed {
            background: white;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 25px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            border: 2px solid #ffcc00;
            margin-top: 20px;
        }
        
        .feed-title {
            font-size: 1.3rem;
            color: #ff6600;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px dashed #ffcc00;
        }
        
        .activity-item {
            padding: 15px;
            margin-bottom: 15px;
            border-left: 4px solid #ffcc00;
            background-color: #fffdf0;
            border-radius: 0 10px 10px 0;
        }
        
        .activity-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
        }
        
        .activity-title {
            font-weight: bold;
            color: #333;
        }
        
        .activity-category {
            background: #ffebcc;
            color: #ff6600;
            padding: 3px 8px;
            border-radius: 15px;
            font-size: 0.8rem;
        }
        
        .activity-status {
            background: #e6f7ff;
            color: #1890ff;
            padding: 3px 8px;
            border-radius: 15px;
            font-size: 0.8rem;
        }
        
        .activity-time {
            color: #999;
            font-size: 0.8rem;
        }
        
        .confidence {
            color: #52c41a;
            font-weight: bold;
        }
        
        .highlight {
            background: linear-gradient(120deg, #ffff99 0%, #ffff99 100%);
            background-repeat: no-repeat;
            background-size: 100% 40%;
            background-position: 0 85%;
            transition: background-size 0.25s ease-in-out;
        }
        
        .pulse {
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(255, 102, 0, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(255, 102, 0, 0); }
            100% { box-shadow: 0 0 0 0 rgba(255, 102, 0, 0); }
        }
        
        .status-indicator {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin-right: 5px;
        }
        
        .status-active {
            background-color: #52c41a;
        }
        
        .status-watching {
            background-color: #1890ff;
        }
        
        .status-building {
            background-color: #faad14;
        }
        
        .status-shipped {
            background-color: #722ed1;
        }
        
        .status-hold {
            background-color: #f5222d;
        }
        
        footer {
            text-align: center;
            padding: 20px;
            margin-top: 30px;
            color: #666;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1><span class="highlight">诸葛灯泡</span> - AI智能信号雷达</h1>
            <p class="subtitle">探长 24 小时自动巡逻，实时追踪市场信号</p>
            <div style="display: flex; justify-content: center; align-items: center; gap: 10px; margin-top: 10px;">
                <span class="status-indicator status-active"></span>
                <strong>系统状态：</strong>
                <span id="system-status">运行中</span>
                <span id="last-update"></span>
            </div>
        </header>
        
        <div class="dashboard">
            <div class="card pulse">
                <h2 class="card-title">总信号数</h2>
                <div class="signal-count" id="total-signals">0</div>
                <p style="text-align: center; color: #666;">当前活跃信号总数</p>
            </div>
            
            <div class="card">
                <h2 class="card-title">按类别分布</h2>
                <ul class="category-list" id="category-list">
                    <!-- 类别数据将通过JavaScript填充 -->
                </ul>
            </div>
            
            <div class="card">
                <h2 class="card-title">按状态分布</h2>
                <ul class="status-list" id="status-list">
                    <!-- 状态数据将通过JavaScript填充 -->
                </ul>
            </div>
        </div>
        
        <div class="activity-feed">
            <h2 class="feed-title">实时活动日志</h2>
            <div id="activity-log">
                <!-- 活动日志将通过JavaScript填充 -->
            </div>
        </div>
        
        <footer>
            <p>诸葛灯泡 © 2026 - 实时信号监控系统</p>
            <p>探长 24 小时自动巡逻，确保不错过任何重要信号</p>
        </footer>
    </div>

    <script>
        // 模拟从后端获取数据
        async function fetchSignalData() {
            // 在实际应用中，这里会调用API获取实时数据
            // 目前使用模拟数据
            return {
                "timestamp": new Date().toISOString(),
                "total_signals": 432,
                "by_category": {
                    "GitHub Trends": 94,
                    "arXiv Papers": 89,
                    "Market Signals": 59,
                    "Tech News": 91,
                    "Competitor Analysis": 104
                },
                "by_status": {
                    "Watching": 125,
                    "Validating": 11,
                    "Building": 5,
                    "Shipped": 58,
                    "On Hold": 114
                },
                "recent_activity": [
                    {
                        "id": "sig_1",
                        "title": "信号 #1: GitHub 上出现新的 AI 开源项目",
                        "category": "GitHub Trends",
                        "status": "Shipped",
                        "timestamp": Date.now()/1000 - 100,
                        "confidence": 0.84
                    },
                    {
                        "id": "sig_2",
                        "title": "信号 #2: 新的竞争对手发布产品",
                        "category": "Competitor Analysis",
                        "status": "Validating",
                        "timestamp": Date.now()/1000 - 200,
                        "confidence": 0.84
                    },
                    {
                        "id": "sig_3",
                        "title": "信号 #3: 最新 arXiv 论文揭示新趋势",
                        "category": "arXiv Papers",
                        "status": "Watching",
                        "timestamp": Date.now()/1000 - 300,
                        "confidence": 0.9
                    },
                    {
                        "id": "sig_4",
                        "title": "信号 #4: 科技新闻报道新兴市场",
                        "category": "Tech News",
                        "status": "Watching",
                        "timestamp": Date.now()/1000 - 400,
                        "confidence": 0.78
                    },
                    {
                        "id": "sig_5",
                        "title": "信号 #5: 市场信号显示需求变化",
                        "category": "Market Signals",
                        "status": "On Hold",
                        "timestamp": Date.now()/1000 - 500,
                        "confidence": 0.67
                    }
                ]
            };
        }
        
        // 更新时间戳格式化函数
        function formatDate(timestamp) {
            const date = new Date(timestamp * 1000);
            return date.toLocaleString('zh-CN');
        }
        
        // 渲染总信号数
        function renderTotalSignals(data) {
            document.getElementById('total-signals').textContent = data.total_signals;
        }
        
        // 渲染类别分布
        function renderCategoryList(data) {
            const categoryList = document.getElementById('category-list');
            categoryList.innerHTML = '';
            
            for (const [category, count] of Object.entries(data.by_category)) {
                const li = document.createElement('li');
                li.className = 'category-item';
                li.innerHTML = `
                    <span>${category}</span>
                    <span>${count}</span>
                `;
                categoryList.appendChild(li);
            }
        }
        
        // 渲染状态分布
        function renderStatusList(data) {
            const statusList = document.getElementById('status-list');
            statusList.innerHTML = '';
            
            for (const [status, count] of Object.entries(data.by_status)) {
                const li = document.createElement('li');
                li.className = 'status-item';
                
                let statusColorClass = '';
                switch(status) {
                    case 'Watching':
                        statusColorClass = 'status-watching';
                        break;
                    case 'Building':
                        statusColorClass = 'status-building';
                        break;
                    case 'Shipped':
                        statusColorClass = 'status-shipped';
                        break;
                    case 'On Hold':
                        statusColorClass = 'status-hold';
                        break;
                    default:
                        statusColorClass = 'status-watching';
                }
                
                li.innerHTML = `
                    <span>
                        <span class="status-indicator ${statusColorClass}"></span>
                        ${status}
                    </span>
                    <span>${count}</span>
                `;
                statusList.appendChild(li);
            }
        }
        
        // 渲染活动日志
        function renderActivityLog(data) {
            const activityLog = document.getElementById('activity-log');
            activityLog.innerHTML = '';
            
            data.recent_activity.forEach(activity => {
                const activityItem = document.createElement('div');
                activityItem.className = 'activity-item';
                
                let statusColorClass = '';
                switch(activity.status) {
                    case 'Watching':
                        statusColorClass = 'status-watching';
                        break;
                    case 'Building':
                        statusColorClass = 'status-building';
                        break;
                    case 'Shipped':
                        statusColorClass = 'status-shipped';
                        break;
                    case 'On Hold':
                        statusColorClass = 'status-hold';
                        break;
                    default:
                        statusColorClass = 'status-watching';
                }
                
                activityItem.innerHTML = `
                    <div class="activity-header">
                        <span class="activity-title">${activity.title}</span>
                        <span class="activity-category">${activity.category}</span>
                    </div>
                    <div style="margin-top: 8px; display: flex; justify-content: space-between; align-items: center;">
                        <span class="activity-status">
                            <span class="status-indicator ${statusColorClass}"></span>
                            ${activity.status}
                        </span>
                        <span class="activity-time">${formatDate(activity.timestamp)}</span>
                    </div>
                    <div style="margin-top: 5px;">
                        <span>置信度: <span class="confidence">${(activity.confidence * 100).toFixed(0)}%</span></span>
                    </div>
                `;
                activityLog.appendChild(activityItem);
            });
        }
        
        // 更新最后更新时间
        function updateLastUpdateTime() {
            const now = new Date();
            document.getElementById('last-update').textContent = `| 最后更新: ${now.toLocaleTimeString('zh-CN')}`;
        }
        
        // 初始化页面
        async function initPage() {
            try {
                // 获取数据
                const data = await fetchSignalData();
                
                // 渲染各部分
                renderTotalSignals(data);
                renderCategoryList(data);
                renderStatusList(data);
                renderActivityLog(data);
                updateLastUpdateTime();
                
                // 每分钟更新一次数据
                setInterval(async () => {
                    const updatedData = await fetchSignalData();
                    renderTotalSignals(updatedData);
                    renderCategoryList(updatedData);
                    renderStatusList(updatedData);
                    renderActivityLog(updatedData);
                    updateLastUpdateTime();
                }, 60000);
            } catch (error) {
                console.error('获取数据失败:', error);
                document.getElementById('total-signals').textContent = '加载失败';
            }
        }
        
        // 页面加载完成后初始化
        document.addEventListener('DOMContentLoaded', initPage);
    </script>
</body>
</html>