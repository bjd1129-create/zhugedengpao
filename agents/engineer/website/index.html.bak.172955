<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>诸葛灯泡 - 信号雷达商业平台</title>
    <style>
        /* 诸葛灯泡商业平台 - 奶油气泡风格 */
        body {
            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background-color: #fff9e6;
            margin: 0;
            padding: 0;
            color: #333;
            line-height: 1.6;
            background-image: radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.1) 1.5%, transparent 1.5%), radial-gradient(circle at 90% 80%, rgba(255, 255, 255, 0.1) 1.5%, transparent 1.5%);
            background-size: 30px 30px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        header {
            text-align: center;
            padding: 40px 20px;
            border-bottom: 2px dashed #ffcc00;
            margin-bottom: 40px;
            background-color: rgba(255, 255, 255, 0.6);
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            box-shadow: 0 4px 20px rgba(255, 204, 0, 0.2);
        }
        
        h1 {
            font-size: 2.8rem;
            color: #ff6600;
            margin: 0;
            text-shadow: 2px 2px 0px rgba(255, 102, 0, 0.1);
        }
        
        .subtitle {
            font-size: 1.2rem;
            color: #666;
            margin-top: 10px;
        }
        
        .section {
            background: white;
            margin: 30px 0;
            padding: 30px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #ffcc00;
            box-shadow: 0 6px 15px rgba(255, 204, 0, 0.15);
        }
        
        h2 {
            color: #ff6600;
            border-bottom: 2px dashed #ffcc00;
            padding-bottom: 10px;
            display: inline-block;
        }
        
        .pricing-plans {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-top: 20px;
        }
        
        .plan {
            background: #fff9e6;
            padding: 25px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px solid #ffcc00;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        
        .plan h3 {
            color: #ff6600;
            font-size: 1.8rem;
            margin-top: 0;
        }
        
        .price {
            font-size: 2.5rem;
            color: #ff3300;
            font-weight: bold;
            margin: 15px 0;
        }
        
        .price span {
            font-size: 1rem;
            color: #666;
        }
        
        .features {
            list-style: none;
            padding: 0;
            text-align: left;
            margin: 20px 0;
        }
        
        .features li {
            padding: 8px 0;
            border-bottom: 1px dashed #ffdd66;
            display: flex;
            align-items: center;
        }
        
        .features li:before {
            content: "✓";
            color: #ff6600;
            font-weight: bold;
            margin-right: 10px;
        }
        
        .btn {
            background: linear-gradient(to right, #ffcc00, #ff9900);
            color: white;
            border: none;
            padding: 12px 30px;
            font-size: 1.1rem;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            margin-top: 15px;
        }
        
        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 12px rgba(255, 153, 0, 0.3);
        }
        
        .highlight {
            background: linear-gradient(120deg, #ffcc00, #ffcc00 100%, transparent 100%);
            background-repeat: no-repeat;
            background-size: 100% 40%;
            background-position: 0 90%;
            padding: 0 5px;
        }
        
        .newsletter {
            display: flex;
            gap: 15px;
            margin-top: 20px;
            flex-wrap: wrap;
        }
        
        .newsletter input {
            flex: 1;
            padding: 12px 15px;
            border: 2px dashed #ffcc00;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            font-size: 1rem;
            min-width: 250px;
        }
        
        .newsletter button {
            background: linear-gradient(to right, #ff6600, #ff3300);
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            cursor: pointer;
        }
        
        .signals-summary {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        
        .signal-card {
            background: #fffde7;
            padding: 20px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #ffcc00;
            text-align: center;
        }
        
        .signal-value {
            font-size: 2rem;
            font-weight: bold;
            color: #ff6600;
        }
        
        .signal-label {
            color: #666;
            margin-top: 5px;
        }
        
        footer {
            text-align: center;
            padding: 30px;
            margin-top: 50px;
            border-top: 2px dashed #ffcc00;
            color: #666;
        }
        
        @media (max-width: 768px) {
            .pricing-plans {
                grid-template-columns: 1fr;
            }
            
            h1 {
                font-size: 2.2rem;
            }
            
            .newsletter input {
                min-width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>诸葛灯泡 <span class="highlight">商业智能平台</span></h1>
            <p class="subtitle">专业信号雷达服务，驱动您的业务增长</p>
        </header>
        
        <section class="section">
            <h2>📊 信号数据概览</h2>
            <div class="signals-summary" id="signals-data">
                <!-- 数据将通过JavaScript动态加载 -->
            </div>
        </section>
        
        <section class="section">
            <h2>💰 商业方案</h2>
            <div class="pricing-plans">
                <div class="plan">
                    <h3>基础版</h3>
                    <div class="price">$79<span>/月</span></div>
                    <ul class="features">
                        <li>每日10个高质量信号</li>
                        <li>基础分析报告</li>
                        <li>邮件支持</li>
                        <li>标准API访问</li>
                    </ul>
                    <a href="#" class="btn">立即开始</a>
                </div>
                
                <div class="plan">
                    <h3>专业版</h3>
                    <div class="price">$199<span>/月</span></div>
                    <ul class="features">
                        <li>每日50个高质量信号</li>
                        <li>深度分析报告</li>
                        <li>优先技术支持</li>
                        <li>高级API访问</li>
                        <li>自定义筛选器</li>
                    </ul>
                    <a href="#" class="btn">获取专业版</a>
                </div>
                
                <div class="plan">
                    <h3>企业版</h3>
                    <div class="price">定制报价</div>
                    <ul class="features">
                        <li>无限信号访问</li>
                        <li>专属客户经理</li>
                        <li>实时数据推送</li>
                        <li>私有化部署选项</li>
                        <li>白标解决方案</li>
                    </ul>
                    <a href="#" class="btn">联系我们</a>
                </div>
            </div>
        </section>
        
        <section class="section">
            <h2>📧 订阅我们的洞察报告</h2>
            <p>获取每周精选的行业趋势和市场洞察</p>
            <form class="newsletter" id="newsletter-form">
                <input type="email" placeholder="输入您的邮箱地址" required>
                <button type="submit" class="btn">订阅</button>
            </form>
        </section>
        
        <footer>
            <p>© 2026 诸葛灯泡 - 专业信号雷达商业平台</p>
            <p>基于先进AI技术，为您提供最准确的市场洞察</p>
        </footer>
    </div>
    
    <script>
        // 动态加载信号数据
        document.addEventListener('DOMContentLoaded', function() {
            // 获取信号数据
            const signalsData = {
                "total_signals": 432,
                "by_category": {
                    "GitHub Trends": 94,
                    "arXiv Papers": 89,
                    "Market Signals": 59,
                    "Tech News": 91,
                    "Competitor Analysis": 104
                },
                "by_status": {
                    "Watching": 125,
                    "Validating": 11,
                    "Building": 5,
                    "Shipped": 58,
                    "On Hold": 114
                }
            };
            
            // 渲染信号数据到页面
            const signalsContainer = document.getElementById('signals-data');
            
            // 显示总信号数
            signalsContainer.innerHTML += `
                <div class="signal-card">
                    <div class="signal-value">${signalsData.total_signals}</div>
                    <div class="signal-label">总信号数</div>
                </div>
            `;
            
            // 显示各类别信号数
            for (const [category, count] of Object.entries(signalsData.by_category)) {
                signalsContainer.innerHTML += `
                    <div class="signal-card">
                        <div class="signal-value">${count}</div>
                        <div class="signal-label">${category}</div>
                    </div>
                `;
            }
            
            // 显示各状态信号数
            for (const [status, count] of Object.entries(signalsData.by_status)) {
                signalsContainer.innerHTML += `
                    <div class="signal-card">
                        <div class="signal-value">${count}</div>
                        <div class="signal-label">${status}</div>
                    </div>
                `;
            }
            
            // 处理订阅表单提交
            const newsletterForm = document.getElementById('newsletter-form');
            if(newsletterForm) {
                newsletterForm.addEventListener('submit', function(e) {
                    e.preventDefault();
                    const email = this.querySelector('input[type="email"]').value;
                    alert(`感谢您订阅我们的洞察报告！我们将发送到 ${email}`);
                    this.reset();
                });
            }
        });
    </script>
</body>
</html>