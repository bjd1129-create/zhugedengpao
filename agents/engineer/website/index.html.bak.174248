<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>诸葛灯泡 - AI智能分析平台</title>
    <style>
        /* 奶油手绘风格全局样式 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background-color: #fff9e6; /* 浅奶油色背景 */
            color: #5a4a42;
            line-height: 1.6;
            background-image: 
                radial-gradient(circle at 15% 30%, rgba(255, 255, 255, 0.1) 1.5px, transparent 1.5px),
                radial-gradient(circle at 50% 70%, rgba(255, 255, 255, 0.1) 1.5px, transparent 1.5px),
                radial-gradient(circle at 85% 40%, rgba(255, 255, 255, 0.1) 1.5px, transparent 1.5px);
            background-size: 30px 30px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        header {
            text-align: center;
            padding: 40px 0;
            border-bottom: 2px dashed #d4c4a8;
            margin-bottom: 40px;
            background-color: rgba(255, 255, 255, 0.6);
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
        }
        
        h1 {
            font-size: 2.5rem;
            color: #8b6b3d;
            margin-bottom: 10px;
        }
        
        .subtitle {
            font-size: 1.2rem;
            color: #a68b5b;
        }
        
        /* 功能卡片区域 */
        .features-section {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 40px;
        }
        
        .feature-card {
            background-color: white;
            padding: 30px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            width: 300px;
            text-align: center;
            border: 2px dashed #d4c4a8;
            box-shadow: 5px 5px 15px rgba(139, 107, 61, 0.1);
            transition: transform 0.3s ease;
        }
        
        .feature-card:hover {
            transform: translateY(-5px);
        }
        
        .feature-card h3 {
            color: #8b6b3d;
            margin-bottom: 15px;
            font-size: 1.4rem;
        }
        
        .feature-card p {
            color: #7a6a5a;
        }
        
        /* Agent状态可视化区域 */
        .agents-section {
            background-color: rgba(255, 255, 255, 0.7);
            padding: 30px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #d4c4a8;
            margin-bottom: 40px;
        }
        
        .section-title {
            text-align: center;
            color: #8b6b3d;
            margin-bottom: 30px;
            font-size: 1.8rem;
        }
        
        .agents-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }
        
        .agent-card {
            background-color: #fffdf4;
            padding: 20px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #e6d8b0;
            position: relative;
            overflow: hidden;
        }
        
        .agent-header {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
        }
        
        .agent-avatar {
            width: 50px;
            height: 50px;
            background-color: #f0e6d2;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            font-weight: bold;
            color: #8b6b3d;
        }
        
        .agent-info h3 {
            color: #8b6b3d;
            margin-bottom: 5px;
        }
        
        .agent-role {
            font-size: 0.9rem;
            color: #a68b5b;
        }
        
        .agent-status {
            display: inline-block;
            padding: 5px 10px;
            border-radius: 15px;
            font-size: 0.8rem;
            margin-top: 10px;
        }
        
        .status-processing {
            background-color: #e6f7ff;
            color: #1890ff;
            border: 1px solid #91d5ff;
        }
        
        .status-resting {
            background-color: #f6ffed;
            color: #52c41a;
            border: 1px solid #b7eb8f;
        }
        
        .agent-stats {
            margin-top: 15px;
            display: flex;
            justify-content: space-between;
            font-size: 0.9rem;
            color: #7a6a5a;
        }
        
        .highlight-box {
            background: linear-gradient(to right, #fffbe6, #fff0b3);
            border-left: 4px solid #ffd666;
            padding: 15px;
            border-radius: 0 15px 15px 0;
            margin: 20px 0;
            font-weight: bold;
            color: #8b6b3d;
        }
        
        /* 实时更新指示器 */
        .live-indicator {
            display: inline-block;
            width: 10px;
            height: 10px;
            background-color: #ff4d4f;
            border-radius: 50%;
            margin-right: 8px;
            animation: pulse 1.5s infinite;
        }
        
        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.4; }
            100% { opacity: 1; }
        }
        
        footer {
            text-align: center;
            padding: 20px;
            color: #a68b5b;
            font-size: 0.9rem;
            border-top: 2px dashed #d4c4a8;
            margin-top: 40px;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>诸葛灯泡</h1>
            <p class="subtitle">AI智能分析与决策支持系统</p>
        </header>
        
        <!-- 静态功能卡片区域 -->
        <section class="features-section">
            <div class="feature-card">
                <h3>智能数据分析</h3>
                <p>利用先进算法对海量数据进行深度挖掘，提供精准分析结果</p>
            </div>
            <div class="feature-card">
                <h3>深度洞察</h3>
                <p>从多维度解读数据背后的趋势与机会，发现隐藏价值</p>
            </div>
            <div class="feature-card">
                <h3>高效执行</h3>
                <p>自动化执行策略，确保决策快速转化为实际行动</p>
            </div>
        </section>
        
        <!-- Agent状态可视化区域 -->
        <section class="agents-section">
            <h2 class="section-title">实时Agent状态监控</h2>
            
            <div class="highlight-box">
                <span class="live-indicator"></span>
                <span id="signals-today">正在处理今日数据...</span>
            </div>
            
            <div class="agents-grid" id="agents-container">
                <!-- Agent卡片将通过JavaScript动态生成 -->
            </div>
        </section>
        
        <footer>
            <p>诸葛灯泡 - 让数据驱动智慧决策</p>
        </footer>
    </div>

    <script>
        // Agent配置数据
        const agents = [
            {
                id: 'Nexus',
                name: 'Nexus',
                role: '数据聚合专家',
                status: 'Processing',
                eventsToday: 0,
                lastActivity: new Date().toLocaleTimeString()
            },
            {
                id: 'Scout',
                name: 'Scout',
                role: '趋势侦察兵',
                status: 'Processing',
                eventsToday: 0,
                lastActivity: new Date().toLocaleTimeString()
            },
            {
                id: 'Quill',
                name: 'Quill',
                role: '内容创作师',
                status: 'Resting',
                eventsToday: 0,
                lastActivity: new Date().toLocaleTimeString()
            },
            {
                id: 'Forge',
                name: 'Forge',
                role: '策略构建者',
                status: 'Processing',
                eventsToday: 0,
                lastActivity: new Date().toLocaleTimeString()
            },
            {
                id: 'Guide',
                name: 'Guide',
                role: '决策引导师',
                status: 'Resting',
                eventsToday: 0,
                lastActivity: new Date().toLocaleTimeString()
            }
        ];
        
        // 渲染Agent卡片的函数
        function renderAgents() {
            const container = document.getElementById('agents-container');
            container.innerHTML = ''; // 清空容器
            
            agents.forEach(agent => {
                const agentCard = document.createElement('div');
                agentCard.className = 'agent-card';
                
                agentCard.innerHTML = `
                    <div class="agent-header">
                        <div class="agent-avatar">${agent.id.charAt(0)}</div>
                        <div class="agent-info">
                            <h3>${agent.name}</h3>
                            <div class="agent-role">${agent.role}</div>
                        </div>
                    </div>
                    <div class="agent-status status-${agent.status.toLowerCase()}">
                        状态: ${agent.status === 'Processing' ? '处理中' : '休眠中'}
                    </div>
                    <div class="agent-stats">
                        <div>今日事件: <strong>${agent.eventsToday}</strong></div>
                        <div>最后活动: ${agent.lastActivity}</div>
                    </div>
                `;
                
                container.appendChild(agentCard);
            });
        }
        
        // 更新信号总数的函数
        function updateSignalsCount() {
            // 这里我们模拟从office_status.json获取数据
            // 在实际应用中，这里应该是一个API调用
            fetch('./office_status.json')
                .then(response => response.json())
                .then(data => {
                    const totalSignals = data.total_signals || 0;
                    document.getElementById('signals-today').textContent = 
                        `实时监控：今日已处理 ${totalSignals} 个信号`;
                    
                    // 更新每个Agent的事件计数
                    agents.forEach(agent => {
                        // 根据总信号数按比例分配给各个Agent
                        // 这里是模拟逻辑，实际应用中应有更精确的数据来源
                        agent.eventsToday = Math.floor(totalSignals / agents.length * Math.random() * 0.5 + 1);
                    });
                    
                    // 重新渲染Agent卡片以显示更新后的数据
                    renderAgents();
                })
                .catch(error => {
                    console.error('获取数据失败:', error);
                    document.getElementById('signals-today').textContent = 
                        '实时监控：数据加载中...';
                });
        }
        
        // 模拟Agent状态变化
        function simulateAgentActivity() {
            agents.forEach(agent => {
                // 随机改变Agent状态
                if (Math.random() > 0.7) { // 30%概率改变状态
                    agent.status = agent.status === 'Processing' ? 'Resting' : 'Processing';
                    agent.lastActivity = new Date().toLocaleTimeString();
                    
                    // 如果变为Processing状态，增加事件计数
                    if (agent.status === 'Processing') {
                        agent.eventsToday += Math.floor(Math.random() * 3) + 1;
                    }
                }
            });
            
            // 重新渲染Agent卡片
            renderAgents();
        }
        
        // 初始化页面
        function initPage() {
            renderAgents();
            updateSignalsCount();
            
            // 每隔一定时间更新数据
            setInterval(updateSignalsCount, 10000); // 每10秒更新一次
            setInterval(simulateAgentActivity, 5000); // 每5秒模拟一次活动
        }
        
        // 页面加载完成后初始化
        document.addEventListener('DOMContentLoaded', initPage);
    </script>
</body>
</html>