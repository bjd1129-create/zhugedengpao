<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>诸葛灯泡 - 实时信号监控</title>
    <style>
        /* 奶油手绘风格基础样式 */
        body {
            margin: 0;
            padding: 20px;
            background-color: #fff9e6; /* 浅奶油色背景 */
            font-family: 'Comic Sans MS', '楷体', cursive;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(128, 128, 128, 0.05) 1.5px, transparent 2px),
                radial-gradient(circle at 20% 40%, rgba(128, 128, 128, 0.05) 1.5px, transparent 2px),
                radial-gradient(circle at 30% 60%, rgba(128, 128, 128, 0.05) 1.5px, transparent 2px),
                radial-gradient(circle at 40% 80%, rgba(128, 128, 128, 0.05) 1.5px, transparent 2px),
                radial-gradient(circle at 50% 100%, rgba(128, 128, 128, 0.05) 1.5px, transparent 2px),
                radial-gradient(circle at 60% 0%, rgba(128, 128, 128, 0.05) 1.5px, transparent 2px),
                radial-gradient(circle at 70% 20%, rgba(128, 128, 128, 0.05) 1.5px, transparent 2px),
                radial-gradient(circle at 80% 40%, rgba(128, 128, 128, 0.05) 1.5px, transparent 2px),
                radial-gradient(circle at 90% 60%, rgba(128, 128, 128, 0.05) 1.5px, transparent 2px);
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        h1 {
            text-align: center;
            color: #5d4037;
            font-size: 2.5em;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }

        .subtitle {
            text-align: center;
            color: #8d6e63;
            font-size: 1.2em;
            margin-bottom: 30px;
        }

        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding: 20px;
            background: #fffde7;
            border: 2px dashed #d4af37;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
        }

        .total-signals {
            font-size: 1.5em;
            font-weight: bold;
            color: #5d4037;
        }

        .last-updated {
            font-size: 0.9em;
            color: #a1887f;
        }

        .agents-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .agent-card {
            background: #fffde7;
            border: 2px dashed #d4af37;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 20px;
            text-align: center;
            box-shadow: 4px 4px 8px rgba(0,0,0,0.1);
        }

        .agent-title {
            font-size: 1.3em;
            color: #5d4037;
            margin-bottom: 10px;
        }

        .agent-count {
            font-size: 2em;
            font-weight: bold;
            color: #d4af37;
        }

        .agent-status {
            margin-top: 10px;
            font-size: 0.9em;
            color: #a1887f;
        }

        .activity-section {
            background: #fffde7;
            border: 2px dashed #d4af37;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 20px;
            margin-bottom: 30px;
        }

        .section-title {
            font-size: 1.5em;
            color: #5d4037;
            margin-bottom: 20px;
            border-bottom: 2px dashed #d4af37;
            padding-bottom: 10px;
        }

        .signals-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 15px;
        }

        .signal-item {
            background: #ffffff;
            border: 1px solid #d4af37;
            border-radius: 15px 255px 15px 225px/225px 15px 255px 15px;
            padding: 15px;
            position: relative;
        }

        .signal-title {
            font-weight: bold;
            color: #5d4037;
            margin-bottom: 5px;
        }

        .signal-meta {
            display: flex;
            justify-content: space-between;
            font-size: 0.85em;
            color: #8d6e63;
        }

        .signal-confidence {
            background: #ffecb3;
            padding: 3px 8px;
            border-radius: 10px;
            font-weight: bold;
        }

        .status-badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 10px;
            font-size: 0.8em;
            font-weight: bold;
        }

        .status-shipped { background: #c8e6c9; color: #2e7d32; }
        .status-building { background: #b3e5fc; color: #0277bd; }
        .status-validating { background: #fff9c4; color: #f57f17; }
        .status-watching { background: #e1f5fe; color: #006064; }
        .status-on-hold { background: #ffebee; color: #c62828; }

        .loading {
            text-align: center;
            padding: 20px;
            font-size: 1.2em;
            color: #8d6e63;
        }

        .highlight-box {
            background: linear-gradient(to right, #fff9c4, #ffecb3);
            border: 2px solid #d4af37;
            border-radius: 15px 255px 15px 225px/225px 15px 255px 15px;
            padding: 15px;
            margin: 20px 0;
        }

        .category-charts {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }

        .category-item {
            background: #ffffff;
            border: 1px solid #d4af37;
            border-radius: 15px 255px 15px 225px/225px 15px 255px 15px;
            padding: 10px;
            text-align: center;
        }

        .category-name {
            font-weight: bold;
            color: #5d4037;
            margin-bottom: 5px;
        }

        .category-count {
            font-size: 1.5em;
            color: #d4af37;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>诸葛灯泡</h1>
        <div class="subtitle">智能信号追踪系统</div>
        
        <div class="dashboard-header">
            <div class="total-signals">总信号数: <span id="totalSignals">-</span></div>
            <div class="last-updated">最后更新: <span id="lastUpdated">-</span></div>
        </div>
        
        <div class="highlight-box">
            <strong>实时状态面板</strong> - 追踪全网信号变化，为决策提供数据支持
        </div>
        
        <div class="agents-grid" id="agentsGrid">
            <!-- Agent cards will be populated here -->
        </div>
        
        <div class="activity-section">
            <h2 class="section-title">最新活动</h2>
            <div class="signals-list" id="signalsList">
                <!-- Signal items will be populated here -->
            </div>
        </div>
        
        <div class="activity-section">
            <h2 class="section-title">按类别分布</h2>
            <div class="category-charts" id="categoryCharts">
                <!-- Category charts will be populated here -->
            </div>
        </div>
    </div>

    <script>
        // 加载数据函数
        async function loadData() {
            try {
                // 显示加载状态
                document.getElementById('totalSignals').textContent = '加载中...';
                
                // 从 office_status.json 获取数据
                const response = await fetch('./office_status.json');
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const data = await response.json();
                
                // 更新总信号数
                document.getElementById('totalSignals').textContent = data.total_signals;
                
                // 更新时间戳
                const timestamp = new Date(data.timestamp);
                document.getElementById('lastUpdated').textContent = timestamp.toLocaleString('zh-CN');
                
                // 渲染Agent卡片
                renderAgents(data.by_status);
                
                // 渲染信号列表
                renderSignals(data.recent_activity);
                
                // 渲染类别分布
                renderCategories(data.by_category);
                
            } catch (error) {
                console.error('加载数据失败:', error);
                document.getElementById('totalSignals').textContent = '加载失败';
                alert('无法加载数据，请检查网络连接或联系管理员');
            }
        }
        
        // 渲染Agent卡片
        function renderAgents(statusData) {
            const agentsGrid = document.getElementById('agentsGrid');
            agentsGrid.innerHTML = ''; // 清空现有内容
            
            // 定义Agent信息
            const agents = [
                { key: 'Watching', title: '观察中代理', desc: '持续监视信号' },
                { key: 'Validating', title: '验证中代理', desc: '评估信号价值' },
                { key: 'Building', title: '构建中代理', desc: '开发解决方案' },
                { key: 'Shipped', title: '已完成代理', desc: '交付成果' },
                { key: 'On Hold', title: '暂停中代理', desc: '等待进一步指示' }
            ];
            
            agents.forEach(agent => {
                const count = statusData[agent.key] || 0;
                
                const agentCard = document.createElement('div');
                agentCard.className = 'agent-card';
                agentCard.innerHTML = `
                    <div class="agent-title">${agent.title}</div>
                    <div class="agent-count">${count}</div>
                    <div class="agent-status">${agent.desc}</div>
                `;
                
                agentsGrid.appendChild(agentCard);
            });
        }
        
        // 渲染信号列表
        function renderSignals(signals) {
            const signalsList = document.getElementById('signalsList');
            signalsList.innerHTML = ''; // 清空现有内容
            
            signals.forEach(signal => {
                const signalItem = document.createElement('div');
                signalItem.className = 'signal-item';
                
                // 格式化时间
                const signalTime = new Date(signal.timestamp * 1000).toLocaleString('zh-CN');
                
                // 确定状态类名
                let statusClass = '';
                switch(signal.status) {
                    case 'Shipped': statusClass = 'status-shipped'; break;
                    case 'Building': statusClass = 'status-building'; break;
                    case 'Validating': statusClass = 'status-validating'; break;
                    case 'Watching': statusClass = 'status-watching'; break;
                    case 'On Hold': statusClass = 'status-on-hold'; break;
                    default: statusClass = 'status-watching';
                }
                
                signalItem.innerHTML = `
                    <div class="signal-title">${signal.title}</div>
                    <div class="signal-meta">
                        <span>${signal.category}</span>
                        <span class="signal-confidence">置信度 ${(signal.confidence * 100).toFixed(0)}%</span>
                    </div>
                    <div style="margin-top: 8px;">
                        <span class="status-badge ${statusClass}">${signal.status}</span>
                        <span style="font-size: 0.8em; color: #a1887f;">${signalTime}</span>
                    </div>
                `;
                
                signalsList.appendChild(signalItem);
            });
        }
        
        // 渲染类别分布
        function renderCategories(categories) {
            const categoryCharts = document.getElementById('categoryCharts');
            categoryCharts.innerHTML = ''; // 清空现有内容
            
            for (const [category, count] of Object.entries(categories)) {
                const categoryItem = document.createElement('div');
                categoryItem.className = 'category-item';
                
                categoryItem.innerHTML = `
                    <div class="category-name">${category}</div>
                    <div class="category-count">${count}</div>
                `;
                
                categoryCharts.appendChild(categoryItem);
            }
        }
        
        // 页面加载完成后初始化
        document.addEventListener('DOMContentLoaded', function() {
            loadData();
            
            // 设置定时刷新（每30秒）
            setInterval(loadData, 30000);
        });
    </script>
</body>
</html>