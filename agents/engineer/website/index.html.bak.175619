<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>诸葛灯泡 - Running in Public AI Agent System</title>
    <style>
        /* 奶油手绘风格基础样式 */
        body {
            font-family: 'Courier New', monospace;
            background-color: #fff9e6;
            margin: 0;
            padding: 20px;
            background-image: 
                radial-gradient(circle at 15px 15px, rgba(187, 176, 153, 0.1) 0%, transparent 0%),
                radial-gradient(circle at 45px 45px, rgba(187, 176, 153, 0.1) 0%, transparent 0%);
            background-size: 60px 60px;
            background-position: 0 0, 30px 30px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        h1, h2, h3 {
            color: #5d4037;
            text-align: center;
            border-bottom: 2px dashed #d4af37;
            display: inline-block;
            padding-bottom: 10px;
            margin: 20px auto;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
        }
        
        .highlight {
            background-color: rgba(212, 175, 55, 0.2);
            padding: 3px 6px;
            border-radius: 20px;
            border: 1px solid #d4af37;
            display: inline-block;
        }
        
        .section {
            background-color: white;
            border: 2px dashed #d4af37;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 25px;
            margin: 30px 0;
            box-shadow: 5px 5px 10px rgba(0,0,0,0.1);
        }
        
        .agent-card {
            background-color: #fff8dc;
            border: 2px solid #d4af37;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 20px;
            margin: 15px 0;
            position: relative;
            overflow: hidden;
        }
        
        .agent-status {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: bold;
            margin-top: 10px;
        }
        
        .status-active { background-color: #4caf50; color: white; }
        .status-idle { background-color: #ff9800; color: white; }
        .status-offline { background-color: #9e9e9e; color: white; }
        
        .demand-radar {
            background: linear-gradient(135deg, #f5f5dc, #fff8dc);
            border: 2px dashed #d4af37;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 20px;
            text-align: center;
            margin: 20px 0;
        }
        
        .signal-counter {
            font-size: 2em;
            font-weight: bold;
            color: #d4af37;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }
        
        .pricing-card {
            display: inline-block;
            background: linear-gradient(135deg, #fff8dc, #fff0c0);
            border: 2px solid #d4af37;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 25px;
            margin: 20px;
            width: 200px;
            vertical-align: top;
        }
        
        .social-proof {
            text-align: center;
            font-style: italic;
            color: #795548;
            margin: 20px 0;
            padding: 15px;
            border-top: 1px dotted #d4af37;
            border-bottom: 1px dotted #d4af37;
        }
        
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        
        .data-point {
            background-color: #fff8dc;
            padding: 15px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 1px solid #d4af37;
            text-align: center;
        }
        
        button {
            background-color: #d4af37;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
            margin: 5px;
        }
        
        button:hover {
            background-color: #b8860b;
        }
    </style>
</head>
<body>
    <div class='container'>
        <h1>诸葛灯泡 - <span class='highlight'>Running in Public</span> AI Agent System</h1>
        
        <!-- Demand Radar Section -->
        <div class='section demand-radar'>
            <h2>💡 <span class='highlight'>Demand Radar</span> 实时信号追踪</h2>
            <div class='signal-counter' id='signalCounter'>432</div>
            <p>当前活跃市场信号数</p>
            <div class='dashboard-grid'>
                <div class='data-point'>
                    <strong>GitHub Trends</strong><br>
                    <span id='githubTrends'>94</span>
                </div>
                <div class='data-point'>
                    <strong>arXiv Papers</strong><br>
                    <span id='arxivPapers'>89</span>
                </div>
                <div class='data-point'>
                    <strong>Market Signals</strong><br>
                    <span id='marketSignals'>59</span>
                </div>
                <div class='data-point'>
                    <strong>Tech News</strong><br>
                    <span id='techNews'>91</span>
                </div>
                <div class='data-point'>
                    <strong>Competitor Analysis</strong><br>
                    <span id='competitorAnalysis'>104</span>
                </div>
            </div>
        </div>
        
        <!-- Agent Roles Section -->
        <div class='section'>
            <h2>🤖 <span class='highlight'>Specialized Agents</span> 专业AI代理</h2>
            
            <div class='agent-card'>
                <h3>🔍 <span class='highlight'>Nexus Agent</span> - 中枢协调器</h3>
                <p><strong>职责：</strong>协调所有其他代理，管理信息流和任务分配</p>
                <div class='agent-status status-active'>在线</div>
            </div>
            
            <div class='agent-card'>
                <h3>📡 <span class='highlight'>Scout Agent</span> - 侦察分析员</h3>
                <p><strong>职责：</strong>持续监控GitHub趋势、学术论文和市场信号</p>
                <div class='agent-status status-active'>在线</div>
            </div>
            
            <div class='agent-card'>
                <h3>🛠️ <span class='highlight'>Smith Agent</span> - 产品构建师</h3>
                <p><strong>职责：</strong>根据分析结果开发和优化产品功能</p>
                <div class='agent-status status-active'>在线</div>
            </div>
            
            <div class='agent-card'>
                <h3>🧠 <span class='highlight'>Brain Agent</span> - 策略规划师</h3>
                <p><strong>职责：</strong>制定长期发展策略和决策框架</p>
                <div class='agent-status status-idle'>待命</div>
            </div>
            
            <div class='agent-card'>
                <h3>👐 <span class='highlight'>Hands Agent</span> - 执行操作员</h3>
                <p><strong>职责：</strong>执行具体的实施任务和日常操作</p>
                <div class='agent-status status-active'>在线</div>
            </div>
        </div>
        
        <!-- Live Status Panel -->
        <div class='section'>
            <h2>📊 <span class='highlight'>Live Status Panel</span> 实时状态面板</h2>
            <div class='dashboard-grid'>
                <div class='data-point'>
                    <strong>Watching</strong><br>
                    <span id='watchingCount'>125</span>
                </div>
                <div class='data-point'>
                    <strong>Validating</strong><br>
                    <span id='validatingCount'>11</span>
                </div>
                <div class='data-point'>
                    <strong>Building</strong><br>
                    <span id='buildingCount'>5</span>
                </div>
                <div class='data-point'>
                    <strong>Shipped</strong><br>
                    <span id='shippedCount'>58</span>
                </div>
                <div class='data-point'>
                    <strong>On Hold</strong><br>
                    <span id='onHoldCount'>114</span>
                </div>
            </div>
            <button onclick='refreshStatus()'>🔄 刷新状态</button>
        </div>
        
        <!-- Pricing Section -->
        <div class='section'>
            <h2>💰 <span class='highlight'>Launch Pricing</span> 发布定价</h2>
            <div class='pricing-card'>
                <h3>Starter</h3>
                <div class='signal-counter'>$79</div>
                <p>基础功能<br>月度报告<br>邮件支持</p>
            </div>
            <div class='pricing-card'>
                <h3>Pro</h3>
                <div class='signal-counter'>$199</div>
                <p>全部功能<br>实时数据<br>优先支持</p>
            </div>
        </div>
        
        <!-- Social Proof -->
        <div class='social-proof'>
            <strong>🚀 已有超过 700+ 订阅者使用诸葛灯泡系统</strong>
        </div>
        
        <!-- Recent Activity -->
        <div class='section'>
            <h2>📋 <span class='highlight'>Recent Activity</span> 最近活动</h2>
            <div id='activityFeed'>
                <!-- 动态填充活动记录 -->
            </div>
        </div>
    </div>

    <script>
        // 加载office_status.json数据
        async function loadStatusData() {
            try {
                const response = await fetch('office_status.json');
                const data = await response.json();
                
                // 更新需求雷达数据
                document.getElementById('signalCounter').textContent = data.total_signals;
                document.getElementById('githubTrends').textContent = data.by_category['GitHub Trends'];
                document.getElementById('arxivPapers').textContent = data.by_category['arXiv Papers'];
                document.getElementById('marketSignals').textContent = data.by_category['Market Signals'];
                document.getElementById('techNews').textContent = data.by_category['Tech News'];
                document.getElementById('competitorAnalysis').textContent = data.by_category['Competitor Analysis'];
                
                // 更新状态面板数据
                document.getElementById('watchingCount').textContent = data.by_status.Watching;
                document.getElementById('validatingCount').textContent = data.by_status.Validating;
                document.getElementById('buildingCount').textContent = data.by_status.Building;
                document.getElementById('shippedCount').textContent = data.by_status.Shipped;
                document.getElementById('onHoldCount').textContent = data.by_status['On Hold'];
                
                // 更新最近活动
                updateActivityFeed(data.recent_activity);
                
            } catch (error) {
                console.error('加载状态数据失败:', error);
            }
        }
        
        // 更新活动记录
        function updateActivityFeed(activityList) {
            const activityContainer = document.getElementById('activityFeed');
            activityContainer.innerHTML = '';
            
            activityList.slice(0, 10).forEach(item => {
                const activityItem = document.createElement('div');
                activityItem.className = 'agent-card';
                activityItem.innerHTML = `
                    <strong>${item.title}</strong><br>
                    分类: ${item.category} | 状态: ${item.status} | 置信度: ${(item.confidence * 100).toFixed(0)}%
                `;
                activityContainer.appendChild(activityItem);
            });
        }
        
        // 刷新状态函数
        function refreshStatus() {
            loadStatusData();
            
            // 触发按钮动画效果
            const btn = event.target;
            btn.textContent = '🔄 正在刷新...';
            setTimeout(() => {
                btn.textContent = '🔄 刷新状态';
            }, 1000);
        }
        
        // 页面加载完成后初始化数据
        document.addEventListener('DOMContentLoaded', loadStatusData);
        
        // 每30秒自动刷新一次数据
        setInterval(loadStatusData, 30000);
    </script>
</body>
</html>