<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>诸葛灯泡 - 实时信号追踪与智能代理平台</title>
    <style>
        /* 手绘奶油风格主题 */
        :root {
            --primary-color: #ffcc00; /* 黄色高亮笔 */
            --background-color: #fff9e6; /* 浅奶油色背景 */
            --text-color: #333;
            --border-color: #d4af37;
            --card-bg: rgba(255, 252, 230, 0.8);
        }
        
        body {
            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background-color: var(--background-color);
            margin: 0;
            padding: 20px;
            color: var(--text-color);
            background-image: 
                radial-gradient(circle at 15px 15px, rgba(212, 175, 55, 0.1) 3px, transparent 4px),
                radial-gradient(circle at 45px 45px, rgba(212, 175, 55, 0.1) 2px, transparent 3px);
            background-size: 60px 60px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            background-color: var(--card-bg);
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 30px;
            box-shadow: 0 8px 20px rgba(212, 175, 55, 0.2);
            border: 3px solid var(--border-color);
        }
        
        h1 {
            text-align: center;
            color: #8B4513;
            font-size: 2.5em;
            margin-top: 0;
            border-bottom: 2px dashed var(--border-color);
            padding-bottom: 15px;
            background: linear-gradient(to right, var(--primary-color), #ffd700);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .dashboard {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }
        
        .card {
            background-color: white;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 20px;
            box-shadow: 0 4px 12px rgba(212, 175, 55, 0.2);
            border: 2px solid var(--border-color);
            position: relative;
            overflow: hidden;
        }
        
        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: var(--primary-color);
        }
        
        .card h2 {
            margin-top: 0;
            color: #8B4513;
            border-bottom: 1px dashed var(--border-color);
            padding-bottom: 10px;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin: 20px 0;
        }
        
        .stat-item {
            text-align: center;
            padding: 15px;
            background: linear-gradient(135deg, #fffbe8, #fff8dc);
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 1px dashed var(--border-color);
        }
        
        .stat-number {
            font-size: 2em;
            font-weight: bold;
            color: var(--primary-color);
            display: block;
        }
        
        .stat-label {
            font-size: 0.9em;
            color: #666;
        }
        
        .activity-list {
            list-style: none;
            padding: 0;
        }
        
        .activity-item {
            padding: 12px;
            margin: 8px 0;
            background: #fffdf0;
            border-radius: 15px 255px 15px 225px/225px 15px 255px 15px;
            border-left: 4px solid var(--primary-color);
            font-size: 0.95em;
        }
        
        .status-badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 0.8em;
            font-weight: bold;
            margin-left: 10px;
        }
        
        .status-Watching { background-color: #e3f2fd; color: #1976d2; }
        .status-Validating { background-color: #fff8e1; color: #ffa000; }
        .status-Building { background-color: #e8f5e9; color: #388e3c; }
        .status-Shipped { background-color: #f3e5f5; color: #7b1fa2; }
        .status-OnHold { background-color: #ffebee; color: #d32f2f; }
        
        .agent-section {
            margin: 30px 0;
            text-align: center;
        }
        
        .agent-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }
        
        .agent-card {
            background: linear-gradient(135deg, #fffbe8, #fff8dc);
            padding: 15px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 1px dashed var(--border-color);
        }
        
        .agent-name {
            font-weight: bold;
            color: #8B4513;
            margin-bottom: 5px;
        }
        
        .agent-role {
            font-size: 0.85em;
            color: #666;
        }
        
        .update-time {
            text-align: center;
            margin-top: 20px;
            color: #8B4513;
            font-style: italic;
        }
        
        .highlight-box {
            background: linear-gradient(45deg, var(--primary-color), #ffd700);
            padding: 20px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            text-align: center;
            margin: 20px 0;
            color: #fff;
            font-weight: bold;
            border: 2px solid #d4af37;
        }
        
        .signal-source {
            display: inline-block;
            background-color: #f0f8ff;
            color: #4682b4;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 0.8em;
            margin-left: 10px;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>诸葛灯泡 - 实时信号追踪与智能代理平台</h1>
        
        <div class="highlight-box">
            🔍 Demand Radar 追踪中: <span id="totalSignals">432</span> 个公开信号
        </div>
        
        <div class="dashboard">
            <div class="card">
                <h2>信号分类统计</h2>
                <div class="stats-grid" id="categoryStats">
                    <!-- Category stats will be populated by JS -->
                </div>
            </div>
            
            <div class="card">
                <h2>处理流水线状态</h2>
                <div class="stats-grid" id="statusStats">
                    <!-- Status stats will be populated by JS -->
                </div>
            </div>
            
            <div class="card">
                <h2>近期活动</h2>
                <ul class="activity-list" id="recentActivity">
                    <!-- Recent activity will be populated by JS -->
                </ul>
            </div>
        </div>
        
        <div class="agent-section">
            <h2>智能代理团队</h2>
            <div class="agent-grid">
                <div class="agent-card">
                    <div class="agent-name">Nexus</div>
                    <div class="agent-role">协调器</div>
                </div>
                <div class="agent-card">
                    <div class="agent-name">Scout</div>
                    <div class="agent-role">侦察员</div>
                </div>
                <div class="agent-card">
                    <div class="agent-name">Quill</div>
                    <div class="agent-role">文案师</div>
                </div>
                <div class="agent-card">
                    <div class="agent-name">Forge</div>
                    <div class="agent-role">建造师</div>
                </div>
                <div class="agent-card">
                    <div class="agent-name">Guide</div>
                    <div class="agent-role">引导员</div>
                </div>
            </div>
        </div>
        
        <div class="update-time" id="updateTime">
            最后更新时间: 加载中...
        </div>
    </div>

    <script>
        // 获取数据并更新页面
        async function updateDashboard() {
            try {
                // 从本地加载数据
                const response = await fetch('data/office_status.json');
                const data = await response.json();
                
                // 更新总数
                document.getElementById('totalSignals').textContent = data.total_signals;
                
                // 更新分类统计
                const categoryStatsContainer = document.getElementById('categoryStats');
                categoryStatsContainer.innerHTML = '';
                for (const [category, count] of Object.entries(data.by_category)) {
                    const statItem = document.createElement('div');
                    statItem.className = 'stat-item';
                    statItem.innerHTML = `
                        <span class="stat-number">${count}</span>
                        <span class="stat-label">${category}</span>
                    `;
                    categoryStatsContainer.appendChild(statItem);
                }
                
                // 更新状态统计
                const statusStatsContainer = document.getElementById('statusStats');
                statusStatsContainer.innerHTML = '';
                for (const [status, count] of Object.entries(data.by_status)) {
                    const statItem = document.createElement('div');
                    statItem.className = 'stat-item';
                    statItem.innerHTML = `
                        <span class="stat-number">${count}</span>
                        <span class="stat-label">${status}</span>
                    `;
                    statusStatsContainer.appendChild(statItem);
                }
                
                // 更新最近活动
                const recentActivityContainer = document.getElementById('recentActivity');
                recentActivityContainer.innerHTML = '';
                data.recent_activity.forEach(activity => {
                    const activityItem = document.createElement('li');
                    activityItem.className = 'activity-item';
                    
                    // 格式化时间戳为可读格式
                    const date = new Date(activity.timestamp * 1000);
                    const timeString = date.toLocaleString('zh-CN');
                    
                    activityItem.innerHTML = `
                        <strong>${activity.title}</strong>
                        <span class="status-badge status-${activity.status}">${activity.status}</span>
                        <span class="signal-source">${activity.category}</span><br>
                        <small>置信度: ${(activity.confidence * 100).toFixed(0)}% | 时间: ${timeString}</small>
                    `;
                    recentActivityContainer.appendChild(activityItem);
                });
                
                // 更新最后更新时间
                const timestampDate = new Date(data.timestamp);
                document.getElementById('updateTime').textContent = `最后更新时间: ${timestampDate.toLocaleString('zh-CN')}`;
                
            } catch (error) {
                console.error('加载数据失败:', error);
            }
        }
        
        // 页面加载完成后立即更新
        document.addEventListener('DOMContentLoaded', updateDashboard);
        
        // 每30秒自动刷新一次数据
        setInterval(updateDashboard, 30000);
    </script>
</body>
</html>