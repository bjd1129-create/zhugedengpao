<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>诸葛灯泡 - AI驱动的智能决策平台</title>
    <style>
        /* 基础样式重置 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background-color: #fff9e6;
            color: #333;
            line-height: 1.6;
            background-image: 
                radial-gradient(circle at 15px 15px, rgba(200, 180, 120, 0.1) 15%, transparent 16%),
                radial-gradient(circle at 45px 45px, rgba(200, 180, 120, 0.1) 15%, transparent 16%);
            background-size: 60px 60px;
            padding: 20px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        /* 头部样式 */
        header {
            text-align: center;
            padding: 30px 20px;
            margin-bottom: 30px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            background-color: rgba(255, 255, 255, 0.7);
            border: 2px dashed #d4af37;
            position: relative;
            overflow: hidden;
        }
        
        h1 {
            font-size: 2.5rem;
            color: #d4af37;
            margin-bottom: 10px;
            text-shadow: 2px 2px 0px rgba(0,0,0,0.1);
        }
        
        .subtitle {
            font-size: 1.2rem;
            color: #5a5a5a;
            margin-bottom: 20px;
        }
        
        .highlight {
            background-color: rgba(255, 255, 0, 0.3);
            padding: 2px 8px;
            border-radius: 4px;
            font-weight: bold;
        }
        
        /* Agent 角色卡片样式 */
        .agents-section {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            margin: 40px 0;
        }
        
        .agent-card {
            background: white;
            padding: 25px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #d4af37;
            box-shadow: 5px 5px 0px rgba(0,0,0,0.05);
            transition: transform 0.3s ease;
        }
        
        .agent-card:hover {
            transform: translateY(-5px);
        }
        
        .agent-title {
            font-size: 1.4rem;
            color: #d4af37;
            margin-bottom: 10px;
            border-bottom: 2px dashed #d4af37;
            padding-bottom: 10px;
        }
        
        .agent-role {
            font-weight: bold;
            color: #5a5a5a;
            margin-bottom: 10px;
        }
        
        .agent-desc {
            color: #666;
            font-size: 0.95rem;
        }
        
        /* 统计数据样式 */
        .stats-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin: 40px 0;
        }
        
        .stat-card {
            background: white;
            padding: 20px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #d4af37;
            text-align: center;
            box-shadow: 5px 5px 0px rgba(0,0,0,0.05);
        }
        
        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            color: #d4af37;
            margin-bottom: 5px;
        }
        
        .stat-label {
            color: #666;
            font-size: 0.9rem;
        }
        
        /* 信号列表样式 */
        .signals-section {
            background: white;
            padding: 30px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #d4af37;
            margin: 40px 0;
        }
        
        .signals-title {
            font-size: 1.5rem;
            color: #d4af37;
            margin-bottom: 20px;
            border-bottom: 2px dashed #d4af37;
            padding-bottom: 10px;
        }
        
        .signal-item {
            padding: 15px;
            border-bottom: 1px dashed #ccc;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .signal-item:last-child {
            border-bottom: none;
        }
        
        .signal-title {
            font-weight: bold;
            color: #5a5a5a;
        }
        
        .signal-meta {
            font-size: 0.85rem;
            color: #888;
        }
        
        .signal-status {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: bold;
        }
        
        .status-shipped { background-color: #d4f8e8; color: #2e8b57; }
        .status-building { background-color: #fff3cd; color: #856404; }
        .status-validating { background-color: #cce5ff; color: #004085; }
        .status-watching { background-color: #e2e3e5; color: #383d41; }
        .status-hold { background-color: #f8d7da; color: #721c24; }
        
        /* 价值主张部分 */
        .value-proposition {
            background: white;
            padding: 30px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #d4af37;
            margin: 40px 0;
            text-align: center;
        }
        
        .pricing {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-top: 20px;
            flex-wrap: wrap;
        }
        
        .price-tier {
            background: #fff9e6;
            padding: 20px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #d4af37;
            width: 200px;
        }
        
        .price-amount {
            font-size: 2rem;
            color: #d4af37;
            font-weight: bold;
            margin: 10px 0;
        }
        
        .social-proof {
            margin-top: 30px;
            font-size: 1.1rem;
            color: #5a5a5a;
        }
        
        .highlight-yellow {
            background-color: rgba(255, 255, 0, 0.3);
            padding: 2px 8px;
            border-radius: 4px;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- 头部 -->
        <header>
            <h1>诸葛灯泡</h1>
            <p class="subtitle">AI驱动的智能决策平台 - <span class="highlight">五智协同，洞见未来</span></p>
            <p>由一位创造者与五个AI智能体共同构建</p>
        </header>
        
        <!-- 价值主张 -->
        <section class="value-proposition">
            <h2>我们的价值主张</h2>
            <p>诸葛灯泡是一个由五位专业AI智能体协同工作的智能决策平台，专注于捕捉市场机遇、分析技术趋势，并为您的业务提供前瞻性洞察。</p>
            
            <div class="pricing">
                <div class="price-tier">
                    <h3>基础版</h3>
                    <div class="price-amount">$79</div>
                    <p>/月</p>
                </div>
                <div class="price-tier">
                    <h3>专业版</h3>
                    <div class="price-amount">$199</div>
                    <p>/月</p>
                </div>
            </div>
            
            <p class="social-proof">已有 <span class="highlight-yellow">700+</span> 订阅用户通过诸葛灯泡获得先机</p>
        </section>
        
        <!-- Agent 角色介绍 -->
        <section>
            <h2 style="text-align: center; color: #d4af37; margin-bottom: 30px; font-size: 1.8rem;">五智协同 Agent 系统</h2>
            <div class="agents-section">
                <div class="agent-card">
                    <h3 class="agent-title">慧眼 (Scout)</h3>
                    <p class="agent-role">情报收集专家</p>
                    <p class="agent-desc">实时监控GitHub趋势、技术新闻、学术论文等多源信息，捕获潜在市场机会和技术变革信号。</p>
                </div>
                
                <div class="agent-card">
                    <h3 class="agent-title">谋士 (Nexus)</h3>
                    <p class="agent-role">战略分析师</p>
                    <p class="agent-desc">整合各渠道信息，进行深度关联分析，识别跨领域趋势，为决策提供战略依据。</p>
                </div>
                
                <div class="agent-card">
                    <h3 class="agent-title">巧匠 (Smith)</h3>
                    <p class="agent-role">产品构建师</p>
                    <p class="agent-desc">将分析结果转化为具体的产品概念和实施计划，主导从创意到原型的转化过程。</p>
                </div>
                
                <div class="agent-card">
                    <h3 class="agent-title">医师 (Healer)</h3>
                    <p class="agent-role">系统维护师</p>
                    <p class="agent-desc">持续监控系统健康状态，自动修复问题，确保整个智能体系统的稳定运行。</p>
                </div>
                
                <div class="agent-card">
                    <h3 class="agent-title">导师 (Guide)</h3>
                    <p class="agent-role">知识整合师</p>
                    <p class="agent-desc">总结历史经验，优化决策流程，持续提升其他智能体的工作效率和准确性。</p>
                </div>
            </div>
        </section>
        
        <!-- 实时统计 -->
        <section>
            <h2 style="text-align: center; color: #d4af37; margin: 30px 0; font-size: 1.8rem;">实时运营数据</h2>
            <div class="stats-container" id="statsContainer">
                <!-- 动态加载统计数据 -->
            </div>
        </section>
        
        <!-- 最新信号 -->
        <section class="signals-section">
            <h2 class="signals-title">最新信号追踪</h2>
            <div id="signalsList">
                <!-- 动态加载信号列表 -->
            </div>
        </section>
    </div>

    <script>
        // 加载数据函数
        async function loadData() {
            try {
                const response = await fetch('./data/office_status.json');
                const data = await response.json();
                
                // 更新统计数据
                updateStats(data);
                
                // 更新信号列表
                updateSignals(data);
                
            } catch (error) {
                console.error('加载数据失败:', error);
                
                // 如果加载失败，显示默认数据
                const defaultData = {
                    "total_signals": 432,
                    "by_category": {
                        "GitHub Trends": 94,
                        "arXiv Papers": 89,
                        "Market Signals": 59,
                        "Tech News": 91,
                        "Competitor Analysis": 104
                    },
                    "by_status": {
                        "Watching": 125,
                        "Validating": 11,
                        "Building": 5,
                        "Shipped": 58,
                        "On Hold": 114
                    },
                    "recent_activity": [
                        {
                            "id": "sig_1",
                            "title": "信号 #1: 新发现的市场机会",
                            "category": "Competitor Analysis",
                            "status": "Shipped",
                            "timestamp": Date.now()/1000,
                            "confidence": 0.84
                        }
                    ]
                };
                
                updateStats(defaultData);
                updateSignals(defaultData);
            }
        }
        
        // 更新统计数据
        function updateStats(data) {
            const statsContainer = document.getElementById('statsContainer');
            
            // 清空现有内容
            statsContainer.innerHTML = '';
            
            // 创建总信号数卡片
            const totalCard = document.createElement('div');
            totalCard.className = 'stat-card';
            totalCard.innerHTML = `
                <div class="stat-number">${data.total_signals}</div>
                <div class="stat-label">总信号数</div>
            `;
            statsContainer.appendChild(totalCard);
            
            // 创建分类统计卡片
            for (const [category, count] of Object.entries(data.by_category)) {
                const categoryCard = document.createElement('div');
                categoryCard.className = 'stat-card';
                categoryCard.innerHTML = `
                    <div class="stat-number">${count}</div>
                    <div class="stat-label">${category}</div>
                `;
                statsContainer.appendChild(categoryCard);
            }
            
            // 创建状态统计卡片
            for (const [status, count] of Object.entries(data.by_status)) {
                const statusCard = document.createElement('div');
                statusCard.className = 'stat-card';
                statusCard.innerHTML = `
                    <div class="stat-number">${count}</div>
                    <div class="stat-label">${status}</div>
                `;
                statsContainer.appendChild(statusCard);
            }
        }
        
        // 更新信号列表
        function updateSignals(data) {
            const signalsList = document.getElementById('signalsList');
            
            // 清空现有内容
            signalsList.innerHTML = '';
            
            // 添加最近活动
            data.recent_activity.forEach(signal => {
                const signalItem = document.createElement('div');
                signalItem.className = 'signal-item';
                
                // 格式化时间戳
                const date = new Date(signal.timestamp * 1000);
                const timeString = date.toLocaleString('zh-CN');
                
                signalItem.innerHTML = `
                    <div>
                        <div class="signal-title">${signal.title}</div>
                        <div class="signal-meta">${signal.category} • ${timeString} • 置信度 ${(signal.confidence * 100).toFixed(0)}%</div>
                    </div>
                    <div class="signal-status status-${signal.status.toLowerCase().replace(' ', '-')}">${signal.status}</div>
                `;
                
                signalsList.appendChild(signalItem);
            });
        }
        
        // 页面加载完成后获取数据
        document.addEventListener('DOMContentLoaded', loadData);
        
        // 每30秒刷新一次数据
        setInterval(loadData, 30000);
    </script>
</body>
</html>