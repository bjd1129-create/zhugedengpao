<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>诸葛灯泡 - AI智能信号监测平台</title>
    <style>
        /* 重置默认样式 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Caveat', 'Noto Serif SC', serif;
            background-color: #fff9e6;
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(255,249,230,0.3) 2px, transparent 2px),
                radial-gradient(circle at 85% 30%, rgba(255,249,230,0.3) 3px, transparent 3px),
                radial-gradient(circle at 50% 80%, rgba(255,249,230,0.2) 1px, transparent 1px);
            min-height: 100vh;
            padding: 20px;
        }
        
        /* 导航栏样式 */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 30px;
            background-color: #fff9e6;
            border: 2px dashed #d4a017;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(212, 160, 23, 0.2);
        }
        
        .nav-brand {
            font-size: 24px;
            font-weight: bold;
            color: #d4a017;
            text-decoration: none;
        }
        
        .nav-links {
            display: flex;
            gap: 20px;
        }
        
        .nav-links a {
            text-decoration: none;
            color: #5d4037;
            padding: 8px 15px;
            border-radius: 20px;
            transition: all 0.3s ease;
        }
        
        .nav-links a:hover {
            background-color: #ffd54f;
            color: #3e2723;
        }
        
        /* 主容器样式 */
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        
        /* 标题样式 */
        h1 {
            text-align: center;
            font-size: 2.5em;
            color: #d4a017;
            margin-bottom: 20px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }
        
        /* 介绍卡片样式 */
        .intro-card {
            background-color: white;
            border: 2px dashed #d4a017;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 6px 20px rgba(212, 160, 23, 0.15);
            position: relative;
            overflow: hidden;
        }
        
        .intro-card::before {
            content: '';
            position: absolute;
            top: -10px;
            left: -10px;
            right: -10px;
            bottom: -10px;
            border: 4px solid transparent;
            border-image: linear-gradient(45deg, #ffd54f, #d4a017, #ffd54f) 1;
            z-index: -1;
            pointer-events: none;
        }
        
        .intro-card p {
            font-size: 1.2em;
            line-height: 1.6;
            color: #5d4037;
            text-align: center;
        }
        
        /* 商业模式卡片样式 */
        .business-model {
            background-color: #fffde7;
            border: 2px dashed #ffd54f;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 25px;
            margin-bottom: 30px;
            box-shadow: 0 6px 20px rgba(255, 213, 79, 0.2);
        }
        
        .pricing {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        
        .plan {
            background-color: white;
            border: 2px dashed #ffd54f;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 4px 12px rgba(255, 213, 79, 0.15);
        }
        
        .plan h3 {
            color: #d4a017;
            margin-bottom: 15px;
        }
        
        .price {
            font-size: 1.8em;
            font-weight: bold;
            color: #ff8f00;
            margin-bottom: 10px;
        }
        
        /* 信号统计区域样式 */
        .signals-section {
            background-color: white;
            border: 2px dashed #d4a017;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 25px;
            margin-bottom: 30px;
            box-shadow: 0 6px 20px rgba(212, 160, 23, 0.15);
        }
        
        .signal-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }
        
        .stat-item {
            background-color: #fff9e6;
            border: 1px solid #ffd54f;
            border-radius: 15px;
            padding: 15px;
            text-align: center;
        }
        
        .stat-value {
            font-size: 1.8em;
            font-weight: bold;
            color: #d4a017;
        }
        
        .stat-label {
            font-size: 0.9em;
            color: #5d4037;
        }
        
        /* 信号状态分布样式 */
        .signal-status-distribution {
            margin-top: 20px;
        }
        
        .status-bar {
            height: 30px;
            border-radius: 15px;
            overflow: hidden;
            display: flex;
            margin-top: 10px;
            border: 1px solid #d4a017;
        }
        
        .status-segment {
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            font-size: 0.8em;
        }
        
        /* 代理角色区域样式 */
        .agents-section {
            background-color: white;
            border: 2px dashed #d4a017;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 25px;
            margin-bottom: 30px;
            box-shadow: 0 6px 20px rgba(212, 160, 23, 0.15);
        }
        
        .agent-roles {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        
        .agent-role {
            background-color: #fff9e6;
            border: 1px solid #ffd54f;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 20px;
            text-align: center;
        }
        
        .role-icon {
            width: 60px;
            height: 60px;
            background-color: #ffd54f;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 10px;
            font-size: 1.5em;
        }
        
        .role-title {
            color: #d4a017;
            font-weight: bold;
            margin-bottom: 8px;
        }
        
        .role-desc {
            font-size: 0.9em;
            color: #5d4037;
        }
        
        /* 最近活动样式 */
        .activity-section {
            background-color: white;
            border: 2px dashed #d4a017;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            padding: 25px;
            box-shadow: 0 6px 20px rgba(212, 160, 23, 0.15);
        }
        
        .activity-list {
            list-style: none;
        }
        
        .activity-item {
            padding: 15px;
            border-bottom: 1px dashed #ffd54f;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .activity-item:last-child {
            border-bottom: none;
        }
        
        .activity-title {
            font-weight: bold;
            color: #5d4037;
        }
        
        .activity-meta {
            font-size: 0.8em;
            color: #8d6e63;
        }
        
        .status-badge {
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 0.8em;
            font-weight: bold;
        }
        
        .status-Watching { background-color: #e3f2fd; color: #1976d2; }
        .status-Validating { background-color: #e8f5e9; color: #388e3c; }
        .status-Building { background-color: #fff3e0; color: #f57c00; }
        .status-Shipped { background-color: #f3e5f5; color: #7b1fa2; }
        .status-On Hold { background-color: #ffebee; color: #d32f2f; }
        
        /* 响应式设计 */
        @media (max-width: 768px) {
            nav {
                flex-direction: column;
                gap: 15px;
            }
            
            .nav-links {
                flex-wrap: wrap;
                justify-content: center;
            }
            
            h1 {
                font-size: 2em;
            }
        }
    </style>
</head>
<body>
    <!-- 导航栏 -->
    <nav>
        <a href="#" class="nav-brand">诸葛灯泡</a>
        <div class="nav-links">
            <a href="#">首页</a>
            <a href="#">产品</a>
            <a href="#">云服务</a>
            <a href="#">现场笔记</a>
            <a href="#">博客</a>
            <a href="#">关于</a>
        </div>
    </nav>
    
    <div class="container">
        <h1>AI智能信号监测平台</h1>
        
        <!-- 介绍卡片 -->
        <div class="intro-card">
            <p>诸葛灯泡是一个先进的AI驱动信号监测平台，通过智能算法实时追踪GitHub趋势、学术论文、市场信号、技术新闻和竞品分析，为您提供最前沿的行业洞察。</p>
        </div>
        
        <!-- 商业模式 -->
        <div class="business-model">
            <h2>我们的商业模式</h2>
            <p>通过提供专业的信号监测和分析服务，我们为企业和个人用户提供订阅制解决方案。</p>
            
            <div class="pricing">
                <div class="plan">
                    <h3>入门版</h3>
                    <div class="price">$79/月</div>
                    <p>基础信号监测</p>
                    <p>每日报告</p>
                    <p>邮件通知</p>
                </div>
                <div class="plan">
                    <h3>专业版</h3>
                    <div class="price">$199/月</div>
                    <p>高级信号分析</p>
                    <p>定制化报告</p>
                    <p>实时推送</p>
                    <p>专属客服</p>
                </div>
            </div>
        </div>
        
        <!-- 信号统计 -->
        <div class="signals-section">
            <h2>信号统计</h2>
            <div class="signal-stats">
                <div class="stat-item">
                    <div class="stat-value" id="total-signals">432</div>
                    <div class="stat-label">总信号数</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="watching-count">372</div>
                    <div class="stat-label">监控中</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="validating-count">8</div>
                    <div class="stat-label">验证中</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="building-count">0</div>
                    <div class="stat-label">构建中</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="shipped-count">52</div>
                    <div class="stat-label">已发布</div>
                </div>
            </div>
            
            <div class="signal-status-distribution">
                <h3>信号状态分布可视化</h3>
                <div class="status-bar">
                    <div class="status-segment" style="background-color: #1976d2; width: 86.1%">Watching (372)</div>
                    <div class="status-segment" style="background-color: #388e3c; width: 1.9%">Validating (8)</div>
                    <div class="status-segment" style="background-color: #f57c00; width: 0%">Building (0)</div>
                    <div class="status-segment" style="background-color: #7b1fa2; width: 12%">Shipped (52)</div>
                </div>
            </div>
        </div>
        
        <!-- 代理角色 -->
        <div class="agents-section">
            <h2>AI代理角色</h2>
            <p>我们的系统由多个专业AI代理协同工作，每个代理专注于特定领域：</p>
            
            <div class="agent-roles">
                <div class="agent-role">
                    <div class="role-icon">🧠</div>
                    <div class="role-title">Nexus协调员</div>
                    <div class="role-desc">负责整体系统协调与任务分配</div>
                </div>
                <div class="agent-role">
                    <div class="role-icon">🔍</div>
                    <div class="role-title">Scout增长</div>
                    <div class="role-desc">专注市场信号与增长机会探测</div>
                </div>
                <div class="agent-role">
                    <div class="role-icon">✍️</div>
                    <div class="role-title">Quill内容</div>
                    <div class="role-title">专注内容生成与信息整理</div>
                </div>
                <div class="agent-role">
                    <div class="role-icon">🛠️</div>
                    <div class="role-title">Forge工程</div>
                    <div class="role-desc">负责技术实现与系统维护</div>
                </div>
                <div class="agent-role">
                    <div class="role-icon">🤝</div>
                    <div class="role-title">Guide社区</div>
                    <div class="role-desc">管理社区互动与用户反馈</div>
                </div>
            </div>
        </div>
        
        <!-- 最近活动 -->
        <div class="activity-section">
            <h2>最近活动</h2>
            <ul class="activity-list" id="recent-activity">
                <!-- 活动将通过JavaScript动态加载 -->
            </ul>
        </div>
    </div>
    
    <script>
        // 从 office_status.json 加载数据
        async function loadOfficeStatus() {
            try {
                const response = await fetch('office_status.json');
                const data = await response.json();
                
                // 更新统计数据
                document.getElementById('total-signals').textContent = data.total_signals;
                
                // 更新状态统计
                if (data.by_status) {
                    document.getElementById('watching-count').textContent = data.by_status.Watching || 0;
                    document.getElementById('validating-count').textContent = data.by_status.Validating || 0;
                    document.getElementById('building-count').textContent = data.by_status.Building || 0;
                    document.getElementById('shipped-count').textContent = data.by_status.Shipped || 0;
                }
                
                // 更新最近活动列表
                const activityList = document.getElementById('recent-activity');
                activityList.innerHTML = ''; // 清空现有内容
                
                if (data.recent_activity && data.recent_activity.length > 0) {
                    data.recent_activity.forEach(activity => {
                        const li = document.createElement('li');
                        li.className = 'activity-item';
                        
                        // 格式化时间戳
                        const date = new Date(activity.timestamp * 1000);
                        const formattedDate = date.toLocaleString('zh-CN');
                        
                        li.innerHTML = `
                            <span class="activity-title">${activity.title}</span>
                            <span class="activity-meta">
                                <span class="status-badge status-${activity.status}">${activity.status}</span>
                                ${formattedDate}
                            </span>
                        `;
                        activityList.appendChild(li);
                    });
                } else {
                    activityList.innerHTML = '<li class="activity-item"><span>暂无最近活动</span></li>';
                }
            } catch (error) {
                console.error('加载办公室状态失败:', error);
                
                // 显示错误信息
                const activityList = document.getElementById('recent-activity');
                activityList.innerHTML = '<li class="activity-item"><span>加载数据失败，请稍后重试</span></li>';
            }
        }
        
        // 页面加载完成后执行
        document.addEventListener('DOMContentLoaded', loadOfficeStatus);
    </script>
</body>
</html>