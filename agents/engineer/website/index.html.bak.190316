<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>诸葛灯泡 · 老庄的 AI 助手</title>
  
  <!-- Google Fonts for handwriting style -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=Caveat:wght@400;700&display=swap" rel="stylesheet">
  
  <style>
    /* 诸葛灯泡手绘风格 CSS 变量 */
    :root {
      --bg-cream: #fff9e6;
      --gold-accent: #d4af37;
      --warm-gray: #5a5a5a;
      --light-beige: #fdf8f9;
      --shadow-light: rgba(0,0,0,0.05);
      --highlight-yellow: rgba(255, 215, 0, 0.4);
    }
    
    /* 基础重置和手绘背景 */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Noto Serif SC', serif;
      background-color: var(--bg-cream);
      background-image: 
        radial-gradient(circle at 15px 15px, rgba(200, 180, 120, 0.15) 15%, transparent 16%),
        radial-gradient(circle at 45px 45px, rgba(200, 180, 120, 0.15) 15%, transparent 16%);
      background-size: 60px 60px;
      min-height: 100vh;
      line-height: 1.6;
      color: var(--warm-gray);
    }
    
    /* 主容器 */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }
    
    /* 头部区域 */
    header {
      text-align: center;
      margin-bottom: 40px;
      padding: 20px;
    }
    
    header h1 {
      font-family: 'Ma Shan Zheng', cursive;
      font-size: clamp(42px, 8vw, 72px);
      color: var(--gold-accent);
      text-shadow: 3px 3px 0px rgba(212, 145, 154, 0.2);
      border-bottom: 3px wavy var(--gold-accent);
      padding-bottom: 10px;
      margin-bottom: 10px;
    }
    
    .tagline {
      font-family: 'Caveat', cursive;
      font-size: 1.4rem;
      color: var(--warm-gray);
      opacity: 0.8;
    }
    
    /* 导航链接 */
    .nav-links {
      display: flex;
      gap: 30px;
      justify-content: center;
      flex-wrap: wrap;
      margin: 30px 0;
    }
    
    .nav-link {
      font-family: 'Ma Shan Zheng', cursive;
      font-size: 1.1rem;
      color: var(--warm-gray);
      text-decoration: none;
      padding: 12px 20px;
      border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
      transition: all 0.3s ease;
      background: rgba(255, 255, 255, 0.7);
      border: 2px dashed var(--gold-accent);
      position: relative;
      overflow: hidden;
    }
    
    .nav-link:hover {
      transform: translateY(-2px);
      box-shadow: 5px 5px 0px var(--gold-accent);
      background: rgba(255, 255, 255, 0.9);
      color: var(--gold-accent);
    }
    
    .nav-link::before {
      content: '✨';
      position: absolute;
      top: -10px;
      left: -10px;
      font-size: 1rem;
      opacity: 0;
      transition: all 0.3s;
    }
    
    .nav-link:hover::before {
      opacity: 1;
      transform: rotate(20deg);
    }
    
    /* 主要内容区域 */
    .main-content {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 30px;
      margin-bottom: 40px;
    }
    
    .card {
      background: rgba(255, 255, 255, 0.8);
      border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
      padding: 25px;
      border: 2px solid var(--gold-accent);
      box-shadow: 5px 5px 0px var(--shadow-light);
      transition: all 0.3s ease;
    }
    
    .card:hover {
      transform: rotate(-1deg) scale(1.02);
      box-shadow: 8px 8px 0px var(--gold-accent);
    }
    
    .card h3 {
      font-family: 'Ma Shan Zheng', cursive;
      font-size: 1.5rem;
      color: var(--gold-accent);
      margin-bottom: 15px;
      border-bottom: 2px dashed var(--gold-accent);
      padding-bottom: 8px;
    }
    
    .card p {
      margin-bottom: 15px;
    }
    
    /* 数据统计区域 */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin: 40px 0;
    }
    
    .stat-card {
      background: white;
      border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
      padding: 20px;
      text-align: center;
      border: 2px solid var(--gold-accent);
      box-shadow: 4px 4px 0px var(--shadow-light);
    }
    
    .stat-number {
      font-family: 'Caveat', cursive;
      font-size: 2.5rem;
      color: var(--gold-accent);
      display: block;
      margin-bottom: 5px;
    }
    
    .stat-label {
      font-size: 0.9rem;
      color: var(--warm-gray);
    }
    
    /* CTA 区域 */
    .cta-section {
      text-align: center;
      background: white;
      border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
      padding: 40px;
      margin: 40px 0;
      border: 3px dashed var(--gold-accent);
    }
    
    .cta-title {
      font-family: 'Ma Shan Zheng', cursive;
      font-size: 2rem;
      color: var(--gold-accent);
      margin-bottom: 20px;
    }
    
    .cta-buttons {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
    }
    
    .btn {
      font-family: 'Ma Shan Zheng', cursive;
      padding: 15px 30px;
      border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
      border: 2px solid var(--gold-accent);
      background: var(--gold-accent);
      color: white;
      font-size: 1.1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      text-decoration: none;
      display: inline-block;
    }
    
    .btn:hover {
      transform: scale(1.05);
      box-shadow: 6px 6px 0px var(--gold-accent);
    }
    
    .btn-outline {
      background: transparent;
      color: var(--gold-accent);
    }
    
    .btn-outline:hover {
      background: var(--gold-accent);
      color: white;
    }
    
    /* Footer */
    footer {
      text-align: center;
      padding: 30px;
      margin-top: 40px;
      border-top: 2px dashed var(--gold-accent);
      color: var(--warm-gray);
    }
    
    /* 手绘装饰元素 */
    .decoration {
      position: fixed;
      font-size: 2rem;
      opacity: 0.1;
      z-index: -1;
      animation: float 8s ease-in-out infinite;
    }
    
    @keyframes float {
      0%, 100% { transform: translateY(0px) rotate(0deg); }
      50% { transform: translateY(-20px) rotate(10deg); }
    }
    
    .deco-1 { top: 10%; left: 5%; animation-delay: 0s; }
    .deco-2 { top: 20%; right: 7%; animation-delay: -2s; }
    .deco-3 { bottom: 15%; left: 8%; animation-delay: -4s; }
    .deco-4 { bottom: 25%; right: 10%; animation-delay: -6s; }
  </style>
</head>
<body>
  <!-- 手绘装饰元素 -->
  <div class="decoration deco-1">💕</div>
  <div class="decoration deco-2">✨</div>
  <div class="decoration deco-3">🚀</div>
  <div class="decoration deco-4">💡</div>
  
  <div class="container">
    <header>
      <h1>诸葛灯泡</h1>
      <p class="tagline">老庄的 AI 助手，不懂代码但善于驾驭 AI 的普通人 💕</p>
      
      <!-- 导航链接 - Product/Cloud/Field Notes 占位 -->
      <nav class="nav-links">
        <a href="#product" class="nav-link">Product</a>
        <a href="#cloud" class="nav-link">Cloud</a>
        <a href="#field-notes" class="nav-link">Field Notes</a>
        <a href="#pricing" class="nav-link">Pricing</a>
      </nav>
    </header>
    
    <!-- 数据统计卡片 -->
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-number" id="total-signals">432</span>
        <div class="stat-label">总信号</div>
      </div>
      <div class="stat-card">
        <span class="stat-number" id="active-signals">141</span>
        <div class="stat-label">活跃信号</div>
      </div>
      <div class="stat-card">
        <span class="stat-number" id="agents-count">8</span>
        <div class="stat-label">智能体</div>
      </div>
      <div class="stat-card">
        <span class="stat-number" id="shipped-signals">58</span>
        <div class="stat-label">已交付</div>
      </div>
    </div>
    
    <div class="main-content">
      <!-- 产品占位卡 -->
      <div class="card" id="product">
        <h3>诸葛产品矩阵</h3>
        <p><strong>需求雷达 Demand Radar</strong> - 实时追踪市场信号，识别潜在机会</p>
        <p><strong>探长 Scout</strong> - 深度分析竞争态势和技术趋势</p>
        <p><strong>巧匠 Smith</strong> - 快速构建和迭代产品原型</p>
        <p><strong>船长 Captain</strong> - 统筹协调各智能体协作</p>
        <p>探长的需求雷达、巧匠的 AI 工具箱、还有更多正在孵化中...</p>
      </div>
      
      <!-- 云服务占位卡 -->
      <div class="card" id="cloud">
        <h3>智能云服务</h3>
        <p>7×24 小时默默工作的智能体团队</p>
        <p><strong>持续监控</strong> - 24小时不间断的市场信号收集</p>
        <p><strong>自动分析</strong> - 智能体自动分类和优先级排序</p>
        <p><strong>实时响应</strong> - 关键信号即时通知和处理</p>
        <p>让AI为你打理繁琐的数据工作，专注核心决策</p>
      </div>
      
      <!-- 实战笔记占位卡 -->
      <div class="card" id="field-notes">
        <h3>实战笔记</h3>
        <p>老庄踩过的坑、总结的经验、最真实的人机协作故事</p>
        <p><strong>案例分享</strong> - 成功/失败案例深度复盘</p>
        <p><strong>工具评测</strong> - AI工具实战体验报告</p>
        <p><strong>方法论</strong> - 人机协作最佳实践</p>
        <p>从0到1的AI创业实战记录</p>
      </div>
      
      <!-- 定价页面占位卡 -->
      <div class="card" id="pricing">
        <h3>灵活定价方案</h3>
        <p><strong>Starter Plan - $79/月</strong></p>
        <ul style="margin-left: 20px; margin-bottom: 15px;">
          <li>基础信号监控 (50个)</li>
          <li>探长 Scout 基础版</li>
          <li>周报邮件</li>
          <li>社区支持</li>
        </ul>
        <p><strong>Pro Plan - $199/月</strong></p>
        <ul style="margin-left: 20px;">
          <li>高级信号监控 (无限)</li>
          <li>全部智能体访问</li>
          <li>实时通知</li>
          <li>专属顾问</li>
          <li>定制化功能</li>
        </ul>
      </div>
    </div>
    
    <!-- 行动号召区域 -->
    <div class="cta-section">
      <h2 class="cta-title">开始你的 AI 创业之旅</h2>
      <p>加入诸葛灯泡，让AI成为你的超级助手</p>
      <div class="cta-buttons">
        <a href="#pricing" class="btn">立即订阅</a>
        <a href="#demo" class="btn btn-outline">观看演示</a>
      </div>
    </div>
    
    <footer>
      <p>诸葛灯泡 © 2026 | Running in Public | 老庄的 AI 创业实验</p>
      <p>让普通人也能驾驭AI的力量 💡</p>
    </footer>
  </div>
  
  <script>
    // 从 office_status.json 加载实时数据
    async function loadRealData() {
      try {
        const response = await fetch('office_status.json');
        if (!response.ok) throw new Error('Network response was not ok');
        
        const data = await response.json();
        
        // 更新统计数据
        document.getElementById('total-signals').textContent = data.total_signals;
        
        // 计算活跃信号数量（Building + Shipped + Validating）
        let activeCount = 0;
        if (data.by_status['Building']) activeCount += data.by_status['Building'];
        if (data.by_status['Shipped']) activeCount += data.by_status['Shipped'];
        if (data.by_status['Validating']) activeCount += data.by_status['Validating'];
        
        document.getElementById('active-signals').textContent = activeCount;
        document.getElementById('shipped-signals').textContent = data.by_status['Shipped'] || 0;
        
        // 假设代理数量为8（根据gap report）
        document.getElementById('agents-count').textContent = 8;
        
        console.log('数据加载成功:', data);
      } catch (error) {
        console.error('加载数据失败:', error);
        // 如果加载失败，保持默认显示
      }
    }
    
    // 页面加载完成后获取数据
    document.addEventListener('DOMContentLoaded', loadRealData);
    
    // 模拟数据更新（每隔30秒）
    setInterval(loadRealData, 30000);
  </script>
</body>
</html>