<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>诸葛灯泡 - AI 驱动的智能信号分析平台</title>
  
  <!-- 样式定义 -->
  <style>
    /* 浅奶油色主题 */
    body {
      background-color: #fff9e6;
      font-family: 'Courier New', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
      margin: 0;
      padding: 20px;
      background-image: 
        radial-gradient(circle at 1em 1em, rgba(180, 180, 180, 0.1) 1px, transparent 1px);
      background-size: 2em 2em;
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }
    
    /* 主标题样式 */
    h1 {
      color: #5d4037;
      text-align: center;
      font-size: 2.5em;
      margin-bottom: 10px;
      text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
    }
    
    .subtitle {
      text-align: center;
      color: #8d6e63;
      font-size: 1.2em;
      margin-bottom: 30px;
    }
    
    /* 信息卡片样式 */
    .info-card {
      background: #ffffff;
      border: 2px dashed #d4af37;
      border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
      padding: 20px;
      margin: 20px 0;
      box-shadow: 5px 5px 15px rgba(0,0,0,0.1);
      position: relative;
      overflow: hidden;
    }
    
    /* 黄色高亮笔效果 */
    .highlight {
      background: linear-gradient(120deg, rgba(255, 255, 0, 0.3), rgba(255, 255, 0, 0.1));
      padding: 2px 5px;
      border-radius: 3px;
      border-bottom: 1px solid rgba(255, 255, 0, 0.5);
    }
    
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin: 20px 0;
    }
    
    .stat-item {
      text-align: center;
      padding: 15px;
      background: #fffde7;
      border: 1px solid #d4af37;
      border-radius: 15px;
      box-shadow: 3px 3px 8px rgba(0,0,0,0.05);
    }
    
    .stat-value {
      font-size: 2em;
      font-weight: bold;
      color: #d4af37;
      display: block;
    }
    
    .stat-label {
      font-size: 0.9em;
      color: #8d6e63;
      margin-top: 5px;
    }
    
    .categories {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 15px;
      margin: 20px 0;
    }
    
    .category-item {
      background: #fff8e1;
      padding: 15px;
      border: 1px solid #ffd54f;
      border-radius: 10px;
    }
    
    .activity-list {
      list-style: none;
      padding: 0;
    }
    
    .activity-item {
      padding: 10px;
      margin: 10px 0;
      background: #fffde7;
      border-left: 4px solid #d4af37;
      border-radius: 0 8px 8px 0;
    }
    
    .status-shipped { color: #2e7d32; }
    .status-building { color: #ff8f00; }
    .status-validating { color: #1976d2; }
    .status-watching { color: #455a64; }
    .status-hold { color: #616161; }
    
    .last-updated {
      text-align: right;
      color: #9e9e9e;
      font-size: 0.9em;
      margin-top: 20px;
    }
    
    .fallback-message {
      text-align: center;
      padding: 20px;
      background: #ffebee;
      border: 2px dashed #e53935;
      border-radius: 15px;
      color: #c62828;
      margin: 20px 0;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>诸葛灯泡</h1>
    <div class="subtitle">AI 驱动的智能信号分析平台</div>
    
    <!-- 总体统计 -->
    <div class="info-card">
      <h2>总体信号统计</h2>
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-value" id="total-signals">-</span>
          <div class="stat-label">总信号数</div>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="github-trends">-</span>
          <div class="stat-label">GitHub 趋势</div>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="arxiv-papers">-</span>
          <div class="stat-label">学术论文</div>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="market-signals">-</span>
          <div class="stat-label">市场信号</div>
        </div>
      </div>
    </div>
    
    <!-- 按状态分类 -->
    <div class="info-card">
      <h2>按状态分类</h2>
      <div class="categories" id="by-status">
        <!-- 状态数据将通过 JS 填充 -->
      </div>
    </div>
    
    <!-- 按类别分类 -->
    <div class="info-card">
      <h2>按类别分类</h2>
      <div class="categories" id="by-category">
        <!-- 类别数据将通过 JS 填充 -->
      </div>
    </div>
    
    <!-- 最近活动 -->
    <div class="info-card">
      <h2>最近活动</h2>
      <ul class="activity-list" id="recent-activity">
        <!-- 活动数据将通过 JS 填充 -->
      </ul>
    </div>
    
    <div class="last-updated" id="last-updated">
      更新时间: 加载中...
    </div>
    
    <div class="fallback-message" id="fallback-message" style="display: none;">
      ⚠️ 注意: 无法获取最新数据，正在显示备用数据
    </div>
  </div>

  <script>
    // 定义备用数据 - 这是当API请求失败时的保底数据
    const fallbackData = {
      "timestamp": new Date().toISOString(),
      "total_signals": 432,
      "by_category": {
        "GitHub Trends": 94,
        "arXiv Papers": 89,
        "Market Signals": 59,
        "Tech News": 91,
        "Competitor Analysis": 104
      },
      "by_status": {
        "Watching": 125,
        "Validating": 11,
        "Building": 5,
        "Shipped": 58,
        "On Hold": 114
      },
      "recent_activity": [
        {
          "id": "sig_1",
          "title": "信号 #1: 新发现的市场机会",
          "category": "Competitor Analysis",
          "status": "Shipped",
          "timestamp": Date.now()/1000,
          "confidence": 0.84
        },
        {
          "id": "sig_2",
          "title": "信号 #2: 新发现的市场机会",
          "category": "Competitor Analysis",
          "status": "Validating",
          "timestamp": (Date.now()-300000)/1000,
          "confidence": 0.84
        },
        {
          "id": "sig_3",
          "title": "信号 #3: 新发现的市场机会",
          "category": "arXiv Papers",
          "status": "Watching",
          "timestamp": (Date.now()-600000)/1000,
          "confidence": 0.9
        },
        {
          "id": "sig_4",
          "title": "信号 #4: 新发现的市场机会",
          "category": "arXiv Papers",
          "status": "Watching",
          "timestamp": (Date.now()-900000)/1000,
          "confidence": 0.78
        },
        {
          "id": "sig_5",
          "title": "信号 #5: 新发现的市场机会",
          "category": "arXiv Papers",
          "status": "On Hold",
          "timestamp": (Date.now()-1200000)/1000,
          "confidence": 0.67
        }
      ]
    };
    
    // 显示数据的函数
    function displayData(data) {
      // 更新总体统计
      document.getElementById('total-signals').textContent = data.total_signals;
      document.getElementById('github-trends').textContent = data.by_category['GitHub Trends'];
      document.getElementById('arxiv-papers').textContent = data.by_category['arXiv Papers'];
      document.getElementById('market-signals').textContent = data.by_category['Market Signals'];
      
      // 更新按状态分类
      const byStatusContainer = document.getElementById('by-status');
      byStatusContainer.innerHTML = '';
      for (const [status, count] of Object.entries(data.by_status)) {
        const statusItem = document.createElement('div');
        statusItem.className = 'category-item';
        statusItem.innerHTML = `
          <div class="highlight">${status}</div>
          <div class="stat-value">${count}</div>
        `;
        byStatusContainer.appendChild(statusItem);
      }
      
      // 更新按类别分类
      const byCategoryContainer = document.getElementById('by-category');
      byCategoryContainer.innerHTML = '';
      for (const [category, count] of Object.entries(data.by_category)) {
        const categoryItem = document.createElement('div');
        categoryItem.className = 'category-item';
        categoryItem.innerHTML = `
          <div class="highlight">${category}</div>
          <div class="stat-value">${count}</div>
        `;
        byCategoryContainer.appendChild(categoryItem);
      }
      
      // 更新最近活动
      const activityList = document.getElementById('recent-activity');
      activityList.innerHTML = '';
      data.recent_activity.forEach(activity => {
        const activityItem = document.createElement('li');
        activityItem.className = 'activity-item';
        
        // 根据状态设置颜色类
        let statusClass = '';
        switch(activity.status.toLowerCase()) {
          case 'shipped':
            statusClass = 'status-shipped';
            break;
          case 'building':
            statusClass = 'status-building';
            break;
          case 'validating':
            statusClass = 'status-validating';
            break;
          case 'watching':
            statusClass = 'status-watching';
            break;
          case 'on hold':
            statusClass = 'status-hold';
            break;
        }
        
        const timeAgo = formatTimeAgo(activity.timestamp);
        activityItem.innerHTML = `
          <strong class="${statusClass}">${activity.status}</strong> - 
          <span>${activity.title}</span><br>
          <small class="highlight">类别: ${activity.category} | 置信度: ${(activity.confidence * 100).toFixed(0)}% | ${timeAgo}</small>
        `;
        activityList.appendChild(activityItem);
      });
      
      // 更新时间
      document.getElementById('last-updated').textContent = `更新时间: ${new Date(data.timestamp).toLocaleString()}`;
    }
    
    // 格式化时间差的函数
    function formatTimeAgo(timestamp) {
      const now = Date.now();
      const timeDiff = now - (timestamp * 1000);
      const minutes = Math.floor(timeDiff / 60000);
      const hours = Math.floor(minutes / 60);
      const days = Math.floor(hours / 24);
      
      if (days > 0) {
        return `${days}天前`;
      } else if (hours > 0) {
        return `${hours}小时前`;
      } else {
        return `${minutes}分钟前`;
      }
    }
    
    // 获取数据的主函数
    async function fetchData() {
      try {
        // 尝试从 API 获取数据
        const response = await fetch('/data/office_status.json');
        
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        
        // 成功获取数据后，隐藏备用消息
        document.getElementById('fallback-message').style.display = 'none';
        
        // 显示获取的数据
        displayData(data);
        
        // 设置定时器，每30秒刷新一次数据
        setTimeout(fetchData, 30000);
      } catch (error) {
        console.error('获取数据失败:', error);
        
        // 显示备用消息
        document.getElementById('fallback-message').style.display = 'block';
        
        // 使用备用数据
        displayData(fallbackData);
        
        // 即使失败也继续尝试刷新，每60秒重试一次
        setTimeout(fetchData, 60000);
      }
    }
    
    // 页面加载完成后开始获取数据
    document.addEventListener('DOMContentLoaded', fetchData);
  </script>
</body>
</html>