<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>诸葛灯泡 - AI驱动的智能信号分析系统</title>
    <style>
        /* 重置默认样式 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background-color: #fff9e6;
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(255, 249, 230, 0.3) 0%, transparent 2%),
                radial-gradient(circle at 85% 30%, rgba(255, 249, 230, 0.3) 0%, transparent 2%);
            color: #333;
            line-height: 1.6;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        /* 头部导航 */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            border-bottom: 2px dashed #ffcc00;
            margin-bottom: 40px;
        }
        
        .logo {
            font-size: 2rem;
            font-weight: bold;
            color: #ff6600;
            text-shadow: 2px 2px 0px rgba(255, 102, 0, 0.1);
            background: linear-gradient(to right, #ff6600, #ffcc00);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        nav ul {
            display: flex;
            list-style: none;
            gap: 30px;
        }
        
        nav a {
            text-decoration: none;
            color: #666;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
            padding: 5px 10px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
        }
        
        nav a:hover {
            color: #ff6600;
            background-color: rgba(255, 204, 0, 0.1);
        }
        
        nav a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background-color: #ff6600;
            transition: width 0.3s ease;
        }
        
        nav a:hover::after {
            width: 100%;
        }
        
        /* 主要英雄区域 */
        .hero {
            text-align: center;
            padding: 60px 20px;
            margin-bottom: 60px;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.3), rgba(255, 234, 167, 0.3));
            border: 2px dashed #ffcc00;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            position: relative;
            overflow: hidden;
        }
        
        .hero h1 {
            font-size: 3.5rem;
            margin-bottom: 20px;
            color: #ff6600;
            text-shadow: 3px 3px 0px rgba(255, 102, 0, 0.1);
        }
        
        .hero p {
            font-size: 1.5rem;
            color: #666;
            margin-bottom: 30px;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }
        
        .cta-button {
            display: inline-block;
            padding: 15px 40px;
            background-color: #ff6600;
            color: white;
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: bold;
            border-radius: 50px;
            border: 2px solid #ffcc00;
            box-shadow: 0 4px 15px rgba(255, 102, 0, 0.3);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .cta-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(255, 102, 0, 0.4);
            background-color: #ff7a2d;
        }
        
        .cta-button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: 0.5s;
        }
        
        .cta-button:hover::before {
            left: 100%;
        }
        
        /* 价值主张卡片 */
        .value-props {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 60px;
        }
        
        .value-card {
            background: white;
            padding: 30px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #ffcc00;
            text-align: center;
            transition: transform 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .value-card:hover {
            transform: translateY(-10px);
        }
        
        .value-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background: linear-gradient(to right, #ff6600, #ffcc00);
        }
        
        .value-card h3 {
            font-size: 1.5rem;
            color: #ff6600;
            margin-bottom: 15px;
        }
        
        .value-card p {
            color: #666;
            margin-bottom: 15px;
        }
        
        .metric {
            font-size: 2.5rem;
            font-weight: bold;
            color: #ff6600;
            margin: 15px 0;
        }
        
        /* 信号统计区域 */
        .signals-stats {
            background: white;
            padding: 40px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #ffcc00;
            text-align: center;
            margin-bottom: 60px;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }
        
        .stat-item {
            padding: 20px;
            background: #fff9e6;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 1px solid #ffcc00;
        }
        
        .stat-number {
            font-size: 2.5rem;
            font-weight: bold;
            color: #ff6600;
            display: block;
        }
        
        .stat-label {
            color: #666;
            font-size: 1rem;
        }
        
        /* 团队介绍 */
        .team-section {
            text-align: center;
            margin-bottom: 60px;
        }
        
        .team-title {
            font-size: 2.5rem;
            color: #ff6600;
            margin-bottom: 40px;
            position: relative;
            display: inline-block;
        }
        
        .team-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 3px;
            background: linear-gradient(to right, #ff6600, #ffcc00);
        }
        
        .team-members {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
        }
        
        .member-card {
            background: white;
            padding: 30px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #ffcc00;
            text-align: center;
        }
        
        .member-avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(45deg, #ffcc00, #ff6600);
            margin: 0 auto 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 2rem;
            font-weight: bold;
        }
        
        .member-name {
            font-size: 1.3rem;
            color: #ff6600;
            margin-bottom: 10px;
        }
        
        .member-role {
            color: #666;
            font-size: 1rem;
            margin-bottom: 10px;
        }
        
        .member-skill {
            background: #fff9e6;
            display: inline-block;
            padding: 5px 15px;
            border-radius: 20px;
            border: 1px solid #ffcc00;
            font-size: 0.9rem;
        }
        
        /* 页脚 */
        footer {
            text-align: center;
            padding: 30px 0;
            border-top: 2px dashed #ffcc00;
            color: #666;
            margin-top: 60px;
        }
        
        /* 响应式设计 */
        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2.5rem;
            }
            
            .hero p {
                font-size: 1.2rem;
            }
            
            nav ul {
                gap: 15px;
            }
            
            .value-card, .stat-item {
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- 头部导航 -->
        <header>
            <div class="logo">诸葛灯泡</div>
            <nav>
                <ul>
                    <li><a href="#home">首页</a></li>
                    <li><a href="#features">功能</a></li>
                    <li><a href="#signals">信号</a></li>
                    <li><a href="#team">团队</a></li>
                    <li><a href="#contact">联系</a></li>
                </ul>
            </nav>
        </header>
        
        <!-- 英雄区域 -->
        <section class="hero" id="home">
            <h1>AI驱动的智能信号分析系统</h1>
            <p>从海量信息中发现下一个投资机会、技术趋势或市场变化</p>
            <a href="#register" class="cta-button">立即注册获取早期访问权限</a>
        </section>
        
        <!-- 价值主张卡片 -->
        <section class="value-props">
            <div class="value-card">
                <h3>准确预测市场信号</h3>
                <p>我们的AI系统帮助您提前发现Polymarket等平台上的下一个暴涨话题，准确率达85%</p>
                <div class="metric">85%</div>
                <p>预测准确率</p>
            </div>
            
            <div class="value-card">
                <h3>实时监控432个信号源</h3>
                <p>覆盖GitHub趋势、学术论文、市场动态、科技新闻和竞品分析，确保不错过任何重要机会</p>
                <div class="metric">432</div>
                <p>活跃信号源</p>
            </div>
            
            <div class="value-card">
                <h3>提升决策效率72%</h3>
                <p>通过智能化分析，大幅提升您的研究和决策效率，专注于最有价值的机会</p>
                <div class="metric">72%</div>
                <p>效率提升</p>
            </div>
        </section>
        
        <!-- 信号统计 -->
        <section class="signals-stats" id="signals">
            <h2>实时信号监控数据</h2>
            <p>我们持续监控多个领域的信号源，为您提供最及时的洞察</p>
            
            <div class="stats-grid">
                <div class="stat-item">
                    <span class="stat-number">432</span>
                    <div class="stat-label">总信号数</div>
                </div>
                <div class="stat-item">
                    <span class="stat-number">94</span>
                    <div class="stat-label">GitHub趋势</div>
                </div>
                <div class="stat-item">
                    <span class="stat-number">89</span>
                    <div class="stat-label">学术论文</div>
                </div>
                <div class="stat-item">
                    <span class="stat-number">59</span>
                    <div class="stat-label">市场信号</div>
                </div>
                <div class="stat-item">
                    <span class="stat-number">91</span>
                    <div class="stat-label">科技新闻</div>
                </div>
                <div class="stat-item">
                    <span class="stat-number">104</span>
                    <div class="stat-label">竞品分析</div>
                </div>
            </div>
        </section>
        
        <!-- 团队介绍 -->
        <section class="team-section" id="team">
            <h2 class="team-title">核心团队</h2>
            <div class="team-members">
                <div class="member-card">
                    <div class="member-avatar">探</div>
                    <h3 class="member-name">探长</h3>
                    <div class="member-role">信号分析师</div>
                    <div class="member-skill">准确率: 85%</div>
                </div>
                
                <div class="member-card">
                    <div class="member-avatar">秀</div>
                    <h3 class="member-name">秀才</h3>
                    <div class="member-role">内容策略师</div>
                    <div class="member-skill">参与度: 72%</div>
                </div>
                
                <div class="member-card">
                    <div class="member-avatar">巧</div>
                    <h3 class="member-name">巧匠</h3>
                    <div class="member-role">首席技术官</div>
                    <div class="member-skill">代码质量: 93%</div>
                </div>
                
                <div class="member-card">
                    <div class="member-avatar">老</div>
                    <h3 class="member-name">老板</h3>
                    <div class="member-role">项目经理</div>
                    <div class="member-skill">执行力: 优秀</div>
                </div>
            </div>
        </section>
        
        <!-- 注册表单区域 -->
        <section class="hero" id="register">
            <h2>获取早期访问权限</h2>
            <p>加入我们的等待列表，第一时间体验诸葛灯泡的强大功能</p>
            <a href="#" class="cta-button">立即注册</a>
        </section>
        
        <!-- 页脚 -->
        <footer>
            <p>&copy; 2026 诸葛灯泡. 让智能信号分析变得简单.</p>
        </footer>
    </div>
</body>
</html>