<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>诸葛灯泡 - AI驱动的智能信号追踪系统</title>
    <style>
        /* 奶油手绘风格CSS */
        body {
            font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background-color: #fff9e6;
            margin: 0;
            padding: 20px;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(255, 255, 255, 0.1) 1.5px, transparent 2px),
                radial-gradient(circle at 20% 35%, rgba(255, 255, 255, 0.1) 1.5px, transparent 2px),
                radial-gradient(circle at 30% 50%, rgba(255, 255, 255, 0.1) 1.5px, transparent 2px),
                radial-gradient(circle at 40% 65%, rgba(255, 255, 255, 0.1) 1.5px, transparent 2px),
                radial-gradient(circle at 50% 80%, rgba(255, 255, 255, 0.1) 1.5px, transparent 2px),
                radial-gradient(circle at 60% 20%, rgba(255, 255, 255, 0.1) 1.5px, transparent 2px),
                radial-gradient(circle at 70% 35%, rgba(255, 255, 255, 0.1) 1.5px, transparent 2px),
                radial-gradient(circle at 80% 50%, rgba(255, 255, 255, 0.1) 1.5px, transparent 2px),
                radial-gradient(circle at 90% 65%, rgba(255, 255, 255, 0.1) 1.5px, transparent 2px);
            background-size: 20px 20px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        header {
            text-align: center;
            margin-bottom: 40px;
            padding: 30px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            background-color: rgba(255, 255, 255, 0.7);
            border: 2px dashed #d4a76a;
            box-shadow: 0 4px 15px rgba(212, 167, 106, 0.2);
        }
        
        h1 {
            color: #5d4037;
            font-size: 2.5em;
            margin: 0 0 10px 0;
            position: relative;
            display: inline-block;
        }
        
        h1:after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(to right, #d4a76a, #ffb74d, #d4a76a);
            border-radius: 2px;
        }
        
        .subtitle {
            color: #8d6e63;
            font-size: 1.2em;
            margin-top: 15px;
        }
        
        .highlight-box {
            background-color: #ffeb3b;
            padding: 15px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px solid #fbc02d;
            margin: 20px 0;
            text-align: center;
            font-weight: bold;
            color: #5d4037;
        }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }
        
        .stat-card {
            background-color: white;
            padding: 25px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #d4a76a;
            text-align: center;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        }
        
        .stat-number {
            font-size: 2.5em;
            font-weight: bold;
            color: #5d4037;
            display: block;
        }
        
        .stat-label {
            color: #8d6e63;
            font-size: 1.1em;
        }
        
        .pricing-section {
            margin: 50px 0;
            text-align: center;
        }
        
        .pricing-title {
            font-size: 1.8em;
            color: #5d4037;
            margin-bottom: 30px;
            border-bottom: 2px dashed #d4a76a;
            padding-bottom: 10px;
            display: inline-block;
        }
        
        .pricing-cards {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
        }
        
        .pricing-card {
            background-color: white;
            padding: 30px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #d4a76a;
            width: 280px;
            box-shadow: 0 6px 15px rgba(212, 167, 106, 0.2);
        }
        
        .pricing-name {
            font-size: 1.5em;
            color: #5d4037;
            margin-bottom: 15px;
        }
        
        .pricing-price {
            font-size: 2.2em;
            font-weight: bold;
            color: #d4a76a;
            margin: 15px 0;
        }
        
        .pricing-features {
            list-style: none;
            padding: 0;
            margin: 20px 0;
            text-align: left;
        }
        
        .pricing-features li {
            padding: 8px 0;
            border-bottom: 1px dashed #eee;
            color: #8d6e63;
        }
        
        .cta-button {
            background-color: #d4a76a;
            color: white;
            border: none;
            padding: 15px 30px;
            font-size: 1.2em;
            border-radius: 50px;
            cursor: pointer;
            margin: 20px 10px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 10px rgba(212, 167, 106, 0.4);
        }
        
        .cta-button:hover {
            background-color: #c0965e;
            transform: translateY(-3px);
            box-shadow: 0 6px 15px rgba(212, 167, 106, 0.6);
        }
        
        .email-subscription {
            background-color: white;
            padding: 30px;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            border: 2px dashed #d4a76a;
            margin: 40px auto;
            max-width: 600px;
            text-align: center;
        }
        
        .email-input {
            padding: 12px 20px;
            font-size: 1em;
            border: 2px solid #d4a76a;
            border-radius: 50px;
            width: 300px;
            margin: 0 10px;
            outline: none;
        }
        
        .email-input:focus {
            box-shadow: 0 0 0 3px rgba(212, 167, 106, 0.3);
        }
        
        .signals-table {
            width: 100%;
            border-collapse: collapse;
            margin: 30px 0;
            background-color: white;
            border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
            overflow: hidden;
            border: 2px dashed #d4a76a;
        }
        
        .signals-table th,
        .signals-table td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px dashed #eee;
        }
        
        .signals-table th {
            background-color: #f5f5dc;
            color: #5d4037;
            font-weight: bold;
        }
        
        .signals-table tr:last-child td {
            border-bottom: none;
        }
        
        footer {
            text-align: center;
            margin-top: 50px;
            padding: 20px;
            color: #8d6e63;
            font-size: 0.9em;
        }
        
        .status-badge {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: bold;
        }
        
        .status-Shipped { background-color: #c8e6c9; color: #2e7d32; }
        .status-Building { background-color: #fff9c4; color: #f57f17; }
        .status-Validating { background-color: #bbdefb; color: #1565c0; }
        .status-Watching { background-color: #e0e0e0; color: #455a64; }
        .status-OnHold { background-color: #ffebee; color: #c62828; }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>诸葛灯泡</h1>
            <p class="subtitle">AI驱动的智能信号追踪系统 | 实时洞察市场趋势与技术动态</p>
            <div class="highlight-box">
                🚀 已追踪 432 个实时信号 | 5大智能Agent协同工作
            </div>
        </header>
        
        <div class="stats-grid">
            <div class="stat-card">
                <span class="stat-number" id="totalSignals">0</span>
                <div class="stat-label">总信号数</div>
            </div>
            <div class="stat-card">
                <span class="stat-number" id="shippedSignals">0</span>
                <div class="stat-label">已完成信号</div>
            </div>
            <div class="stat-card">
                <span class="stat-number" id="buildingSignals">0</span>
                <div class="stat-label">构建中信号</div>
            </div>
            <div class="stat-card">
                <span class="stat-number" id="validatingSignals">0</span>
                <div class="stat-label">验证中信号</div>
            </div>
        </div>
        
        <div style="text-align: center; margin: 40px 0;">
            <button class="cta-button" onclick="location.href='#pricing'">立即开始构建您的系统</button>
            <button class="cta-button" onclick="location.href='#subscribe'" style="background-color: #8d6e63;">获取最新更新</button>
        </div>
        
        <div id="pricing" class="pricing-section">
            <h2 class="pricing-title">选择适合您的方案</h2>
            <div class="pricing-cards">
                <div class="pricing-card">
                    <h3 class="pricing-name">Starter</h3>
                    <div class="pricing-price">$79</div>
                    <ul class="pricing-features">
                        <li>✓ 100 个信号追踪</li>
                        <li>✓ 3个AI Agent</li>
                        <li>✓ 基础分析报告</li>
                        <li>✓ 邮件支持</li>
                    </ul>
                    <button class="cta-button" style="background-color: #81c784;" onclick="alert('感谢您选择Starter计划！')">选择此方案</button>
                </div>
                
                <div class="pricing-card" style="transform: scale(1.05); border: 3px dashed #d4a76a;">
                    <h3 class="pricing-name">Pro</h3>
                    <div class="pricing-price">$199</div>
                    <ul class="pricing-features">
                        <li>✓ 无限信号追踪</li>
                        <li>✓ 5个高级AI Agent</li>
                        <li>✓ 实时分析报告</li>
                        <li>✓ 优先技术支持</li>
                        <li>✓ API访问权限</li>
                    </ul>
                    <button class="cta-button" onclick="alert('感谢您选择Pro计划！')">选择此方案</button>
                </div>
            </div>
        </div>
        
        <div id="subscribe" class="email-subscription">
            <h2>订阅我们的更新</h2>
            <p>获取最新的市场洞察和技术动态，以及产品更新通知</p>
            <form onsubmit="handleSubmit(event)">
                <input type="email" class="email-input" placeholder="输入您的邮箱地址" required>
                <button type="submit" class="cta-button" style="background-color: #5d4037;">订阅</button>
            </form>
        </div>
        
        <h2 style="color: #5d4037; text-align: center; margin: 40px 0 20px 0; border-bottom: 2px dashed #d4a76a; padding-bottom: 10px;">近期活动信号</h2>
        
        <table class="signals-table">
            <thead>
                <tr>
                    <th>信号ID</th>
                    <th>标题</th>
                    <th>分类</th>
                    <th>状态</th>
                    <th>置信度</th>
                </tr>
            </thead>
            <tbody id="signalsTableBody">
                <!-- 动态加载内容 -->
            </tbody>
        </table>
        
        <footer>
            <p>© 2026 诸葛灯泡 - 智能信号追踪系统 | 透明公开所有数据</p>
        </footer>
    </div>
    
    <script>
        // 加载统计数据
        async function loadStats() {
            try {
                // 使用模拟数据，因为实际API可能不可用
                const stats = {
                    total_signals: 432,
                    by_status: {
                        Shipped: 58,
                        Building: 5,
                        Validating: 11,
                        Watching: 125,
                        'On Hold': 114
                    },
                    recent_activity: [
                        {
                            id: "sig_1",
                            title: "信号 #1: 新发现的市场机会",
                            category: "Competitor Analysis",
                            status: "Shipped",
                            confidence: 0.84
                        },
                        {
                            id: "sig_2",
                            title: "信号 #2: 新发现的市场机会",
                            category: "Competitor Analysis",
                            status: "Validating",
                            confidence: 0.84
                        },
                        {
                            id: "sig_3",
                            title: "信号 #3: 新发现的市场机会",
                            category: "arXiv Papers",
                            status: "Watching",
                            confidence: 0.90
                        },
                        {
                            id: "sig_4",
                            title: "信号 #4: 新发现的市场机会",
                            category: "arXiv Papers",
                            status: "Watching",
                            confidence: 0.78
                        },
                        {
                            id: "sig_5",
                            title: "信号 #5: 新发现的市场机会",
                            category: "arXiv Papers",
                            status: "On Hold",
                            confidence: 0.67
                        }
                    ]
                };
                
                document.getElementById('totalSignals').textContent = stats.total_signals;
                document.getElementById('shippedSignals').textContent = stats.by_status.Shipped;
                document.getElementById('buildingSignals').textContent = stats.by_status.Building;
                document.getElementById('validatingSignals').textContent = stats.by_status.Validating;
                
                const tableBody = document.getElementById('signalsTableBody');
                tableBody.innerHTML = '';
                
                stats.recent_activity.forEach(signal => {
                    const row = document.createElement('tr');
                    
                    // 计算置信度百分比
                    const confidencePercent = Math.round(signal.confidence * 100);
                    
                    row.innerHTML = `
                        <td>${signal.id}</td>
                        <td>${signal.title}</td>
                        <td>${signal.category}</td>
                        <td><span class="status-badge status-${signal.status}">${signal.status}</span></td>
                        <td>${confidencePercent}%</td>
                    `;
                    
                    tableBody.appendChild(row);
                });
            } catch (error) {
                console.error('加载统计数据失败:', error);
            }
        }
        
        // 处理邮件订阅
        function handleSubmit(event) {
            event.preventDefault();
            const email = event.target.querySelector('.email-input').value;
            alert(`感谢您订阅！我们将发送更新到 ${email}`);
            event.target.reset();
        }
        
        // 页面加载完成后初始化
        document.addEventListener('DOMContentLoaded', loadStats);
    </script>
</body>
</html>