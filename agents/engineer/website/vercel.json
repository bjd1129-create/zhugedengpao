{
  "framework": null,
  "buildCommand": "echo static",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/tongtong-adventure/:path*",
      "destination": "/tongtong-adventure/dist/:path*"
    }
  ],
  "headers": [
    {
      "source": "/pages/(.*)\\.(jpg|jpeg|png|gif|webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/pages/(.*)\\.(html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/data/(.*)\\.(json)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, stale-while-revalidate=300"
        }
      ]
    }
  ]
}
