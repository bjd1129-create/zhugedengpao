        </div>
      </div>
      <div class="team-card reveal">
        <span class="team-card__emoji">📊</span>
        <div>
          <div class="team-card__name">数据组</div>
          <div class="team-card__role">数据分析 · 报表</div>
        </div>
      </div>
      <div class="team-card reveal">
        <span class="team-card__emoji">🌱</span>
        <div>
          <div class="team-card__name">运营组</div>
