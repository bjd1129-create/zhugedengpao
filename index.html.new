          <div class="team-card__name">调研组</div>
          <div class="team-card__role">信息收集 · 分析</div>
        </div>
      </div>
      <div class="team-card reveal">
        <span class="team-card__emoji">🛡️</span>
        <div>
          <div class="team-card__name">安全组</div>
          <div class="team-card__role">账号安全 · 备份</div>
        </div>
      </div>
      <div class="team-card reveal">
        <span class="team-card__emoji">💰</span>
        <div>
          <div class="team-card__name">财务组</div>
