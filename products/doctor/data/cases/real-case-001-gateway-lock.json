{
  "id": "real-case-001",
  "date": "2026-03-31",
  "source": "老庄 OpenClaw 实例",
  "problems": [
    {
      "id": "sessions-list-slow",
      "symptom": "sessions.list 响应 28-32 秒",
      "rootCauses": [
        "sessions.json 每个 session 含 83KB skillsSnapshot，373 个 session 共 31MB",
        "session-write-lock 持锁 30-78 秒",
        "22 个僵尸 running session 未释放",
        ".jsonl.reset/.deleted 历史文件残留 ~90MB"
      ],
      "detection": [
        "ls -la ~/.openclaw/agents/*/sessions/sessions.json",
        "wc -c ~/.openclaw/agents/*/sessions/sessions.json",
        "jq '[.[] | select(.status==\"running\")] | length' ~/.openclaw/agents/*/sessions/sessions.json",
        "find ~/.openclaw -name '*.jsonl.reset.*' -o -name '*.jsonl.deleted.*' | wc -l"
      ],
      "fix": [
        "压缩 sessions.json：jq 'map(del(.skillsSnapshot, .systemPromptReport))' > tmp && mv tmp sessions.json",
        "删除 .jsonl.reset/.deleted：find ~/.openclaw -name '*.jsonl.reset.*' -delete",
        "修复僵尸 running session：jq 'map(if (.status==\"running\") then .status=\"aborted\" else . end)'",
        "重启 gateway"
      ],
      "successRate": 0.9,
      "resolved": true
    },
    {
      "id": "heartbeat-zombie-processes",
      "symptom": "232 个 heartbeat-runner.js 进程堆积",
      "rootCauses": [
        "run-heartbeat.sh 每次调度不检查旧进程",
        "进程泄漏累积"
      ],
      "detection": [
        "ps aux | grep -c 'heartbeat-runner.js'"
      ],
      "fix": [
        "pkill -f heartbeat-runner.js"
      ],
      "successRate": 1.0,
      "resolved": true
    },
    {
      "id": "clobbered-files",
      "symptom": "30473 个 .clobbered 文件，2.8GB",
      "rootCauses": [
        "配置文件历史备份累积"
      ],
      "detection": [
        "find ~/.openclaw -name '*.clobbered' | wc -l",
        "du -sh ~/.openclaw"
      ],
      "fix": [
        "find ~/.openclaw -name '*.clobbered' -delete"
      ],
      "successRate": 1.0,
      "resolved": true
    }
  ],
  "lessons": [
    "sessions.list 慢不一定是文件 IO，可能是 session 状态异常",
    "skillsSnapshot 是 session 膨胀的主要原因",
    "heartbeat 进程需要防泄漏机制",
    "gateway 重启能清理大部分僵尸状态"
  ]
}
